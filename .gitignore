.DS_Store
Thumbs.db

# Saved scenes
celestial_scene.json
*.scene.json

# Heliochronicles snapshot pipeline — large binaries regenerated locally
# via `npm run data:snapshots`. Tier1/Tier2 JSONs and index.json are small
# and deterministic; commit them when you run a full build.
data/history/archive-hourly/
data/history/archive-daily.bin

# npm — devDependencies only (Playwright); we never check in node_modules.
node_modules/
package-lock.json
test-results/
playwright-report/
