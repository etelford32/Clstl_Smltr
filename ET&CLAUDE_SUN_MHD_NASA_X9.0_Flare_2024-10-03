  document.getElementById('vPCount').textContent = target;
  const curr = plasmaParticles.length;
  if(target > curr){
    for(let p=curr;p<target;p++){
      const la=(Math.random()-0.5)*Math.PI*0.95, lo=Math.random()*Math.PI*2, r=1.02+Math.random()*0.6;
      const geo=new THREE.SphereGeometry(0.009,4,4);
      const mat=new THREE.MeshBasicMaterial({color:0x88ccff,transparent:true,opacity:0.7});
      const mesh=new THREE.Mesh(geo,mat);
      pfGroup.add(mesh);
      plasmaParticles.push({mesh,la,lo,r,speed:0.003+Math.random()*0.004});
    }
  } else {
    while(plasmaParticles.length > target){
      const p = plasmaParticles.pop();
      pfGroup.remove(p.mesh);
    }
  }
});

// ── Flare heat decay in shader ─────────────────────────────────
// Hook into triggerFlare to heat the shader
const _origTrigger = window.triggerFlare;
window.triggerFlare = function(){
  _origTrigger && _origTrigger();
  sunUniforms.uFlareHeat.value = 1.0;
  // Spawn eruptive prominence
  spawnProminence(true, true);
  buildHelmets();
};

// ── Prominence animation ──────────────────────────────────────
let promTimer = 0;
function animateProminences(){
  promTimer++;
  // Spawn new based on density slider
  const spawnRate = Math.max(5, Math.floor(300 / (surfParams.promD * surfParams.flareF + 0.1)));
  if(promTimer % spawnRate === 0 && prominences.length < Math.ceil(8 * surfParams.promD)){
    spawnProminence(false, false);
  }

  // Update flare heat decay
  if(sunUniforms.uFlareHeat.value > 0.001){
    sunUniforms.uFlareHeat.value *= 0.985;
  }

  for(let i=prominences.length-1; i>=0; i--){
    const prom = prominences[i];
    prom.life -= prom.decay;
    prom.riseAccum += prom.riseRate;

    // Fade
    prom.line.material.opacity = Math.max(0, prom.life * (prom.eruptive ? 0.95 : 0.7));

    // Eruptive: rise and expand
    if(prom.eruptive && prom.riseAccum > 0){
      const pos = prom.line.geometry.attributes.position;
      for(let s=0; s<pos.count; s++){
        const rise = prom.riseAccum * (s/pos.count);
        const x=pos.getX(s), y=pos.getY(s), z=pos.getZ(s);
        const r = Math.sqrt(x*x+y*y+z*z);
        const scale = (r + rise*0.01) / r;
        pos.setXYZ(s, x*scale, y*scale, z*scale);
      }
      pos.needsUpdate = true;
    }

    // Animate plasma blobs along arch
    prom.blobs.forEach(blob=>{
      blob.t = (blob.t + blob.speed * blob.dir + 1) % 1;
      const idx2 = Math.floor(blob.t * (prom.pts.length-1));
      const pt = prom.pts[Math.min(idx2, prom.pts.length-1)];
      if(pt) blob.mesh.position.copy(pt);
      blob.mesh.material.opacity = prom.line.material.opacity * 0.9;
    });

    if(prom.life <= 0){
      promGroup.remove(prom.line);
      prom.blobs.forEach(b=>promGroup.remove(b.mesh));
      prominences.splice(i,1);
    }
  }

  // Co-rotate with sun
  promGroup.rotation.y = photoMesh.rotation.y;
  helmGroup.rotation.y = photoMesh.rotation.y;

  // Rebuild helmets occasionally
  if(promTimer % 180 === 0) buildHelmets();
}

// ── Visibility toggles for new layers ────────────────────────
const _origTog = window.tog;
window.tog = function(k){
  _origTog && _origTog(k);
  if(k==='PROM')  promGroup.visible = !promGroup.visible;
  if(k==='HELM')  helmGroup.visible = !helmGroup.visible;
  if(k==='SPIC')  sunUniforms.uSpicules.value = helmGroup.visible ? surfParams.spicules : 0;
};

// ── Hook prominence animation into setInterval ────────────────
setInterval(animateProminences, 50);

