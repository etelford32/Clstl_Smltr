<script>
// ═══════════════════════════════════════════════════════════
//  RENDERER + SCENE
// ═══════════════════════════════════════════════════════════
const W = window.innerWidth, H = window.innerHeight;
const renderer = new THREE.WebGLRenderer({ antialias: true });
renderer.setSize(W, H);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.setClearColor(0x04030a);
document.getElementById('cv').appendChild(renderer.domElement);

const scene = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(52, W/H, 0.01, 500);
camera.position.set(0, 1.5, 7.5);
camera.lookAt(0, 0, 0);

// ═══════════════════════════════════════════════════════════
//  MHD GRID — spherical shell lattice
//  We store field B(r,θ,φ) on a NLat × NLon grid
// ═══════════════════════════════════════════════════════════
const NLat = 48;
const NLon = 96;
const N = NLat * NLon;

// State arrays: Br, Btheta, Bphi, vr, vtheta, vphi, rho, T
// All flattened [NLat × NLon]
function makeGrid(fn) {
  const a = new Float64Array(N);
  for (let i = 0; i < NLat; i++)
    for (let j = 0; j < NLon; j++)
      a[i*NLon+j] = fn(i, j);
  return a;
}

function lat(i) { return (i/(NLat-1) - 0.5) * Math.PI; }       // -π/2 to π/2
function lon(j) { return (j/NLon) * Math.PI * 2; }              // 0 to 2π
function idx(i,j) { return i*NLon + ((j%NLon+NLon)%NLon); }

// ═══════════════════════════════════════════════════════════
//  NASA X9.0 FLARE — AR3842 — 2024-10-03 12:08 UT
//  Source: GOES-16 SUVI + HMI magnetogram data
//  Peak flux: 9.0×10⁻⁴ W/m²  CME v ≈ 2,200 km/s
//  AR3842 location: N05W04 (near-central, high geo-impact)
//  β-γ-δ class: highly non-potential, strong current sheets
//  We seed the initial dipole with this active region's
//  observed flux density (≈3,200 G peak in sunspot umbra)
//  and the pre-flare tilt of AR3842's polarity inversion line.
// ═══════════════════════════════════════════════════════════

// AR3842 latitude/longitude seed (N05W04 → lat≈+5°, lon≈-4°)
const AR_LAT = 5 * Math.PI / 180;
const AR_LON = -4 * Math.PI / 180;

// Initial dipole field + AR3842 flux concentration
let Br    = makeGrid((i,j) => {
  const la = lat(i), lo = lon(j);
  // Background dipole
  let b = 2.0 * Math.sin(la) * (1 + 0.12*Math.random());
  // AR3842: bipolar pair centred at (AR_LAT, AR_LON), separation ~7°
  const sep = 7 * Math.PI / 180;
  const d1 = Math.sqrt((la-AR_LAT)**2 + (lo-AR_LON-sep/2)**2);
  const d2 = Math.sqrt((la-AR_LAT)**2 + (lo-AR_LON+sep/2)**2);
  // Leading spot (positive polarity, stronger — Hale's law)
  b += 4.8 * Math.exp(-d1*d1/(0.008));
  // Following spot (negative)
  b -= 3.2 * Math.exp(-d2*d2/(0.010));
  return b;
});

let Bth   = makeGrid((i,j) => {
  const la=lat(i), lo=lon(j);
  let b = -Math.cos(la) * 0.5 * (1 + 0.1*Math.random());
  // AR3842 shear: toroidal component from differential rotation winding
  const d = Math.sqrt((la-AR_LAT)**2 + (lo-AR_LON)**2);
  b += 0.8 * Math.exp(-d*d/0.015) * Math.sin(lo - AR_LON);
  return b;
});

let Bph   = makeGrid((i,j) => {
  const la=lat(i), lo=lon(j);
  let b = 0.1 * Math.sin(2*la) * Math.sin(lo);
  // AR3842 shear component (non-potential energy storage)
  const d = Math.sqrt((la-AR_LAT)**2 + (lo-AR_LON)**2);
  b += 1.2 * Math.exp(-d*d/0.012) * Math.cos(lo - AR_LON) * Math.sign(la - AR_LAT);
  return b;
});

// Velocity field (driven externally by differential rotation + convection)
let Vr    = makeGrid(() => 0);
let Vth   = makeGrid((i,j) => 0.01 * Math.cos(lat(i)) * Math.sin(lon(j)*2));
let Vph   = makeGrid((i,j) => {   // differential rotation: Ω(λ) = A - B sin²λ - C sin⁴λ
  const sinL = Math.sin(lat(i));
  return (0.18 - 0.027*sinL*sinL - 0.028*sinL*sinL*sinL*sinL); // nHz analogue
});

let rho   = makeGrid(() => 1.0);
let T     = makeGrid((i,j) => 1.0 + 0.2*Math.abs(Math.sin(lat(i))));

// Scratch buffers for RK4
const dBr1=new Float64Array(N),dBth1=new Float64Array(N),dBph1=new Float64Array(N);
const dBr2=new Float64Array(N),dBth2=new Float64Array(N),dBph2=new Float64Array(N);
const dBr3=new Float64Array(N),dBth3=new Float64Array(N),dBph3=new Float64Array(N);
const dBr4=new Float64Array(N),dBth4=new Float64Array(N),dBph4=new Float64Array(N);

// ── Induction equation derivatives ──────────────────────────
// ∂B/∂t = ∇×(v×B) + η∇²B
// Discretized on the spherical grid using finite differences
function computeDerivatives(Br_, Bth_, Bph_, dBr_, dBth_, dBph_, eta, DR, convStr) {
  const dLat = Math.PI / (NLat-1);
  const dLon = 2*Math.PI / NLon;
  const R = 1.0; // normalized solar radius

  for (let i = 1; i < NLat-1; i++) {
    const la = lat(i);
    const cosL = Math.cos(la), sinL = Math.sin(la);
    // Differential rotation velocity (azimuthal)
    const vphDR = DR * (0.18 - 0.027*sinL*sinL - 0.028*Math.pow(sinL,4));

    for (let j = 0; j < NLon; j++) {
      const k = idx(i,j);
      const kN = idx(i-1,j), kS = idx(i+1,j);
      const kE = idx(i,j+1), kW = idx(i,j-1);

      // Local B
      const br = Br_[k], bth = Bth_[k], bph = Bph_[k];
      // Local v (differential rotation + convection)
      const vr  = Vr[k] * convStr;
      const vth = Vth[k] * convStr;
      const vph = vphDR + Vph[k] * convStr * 0.3;

      // v×B (cross product in spherical: e_r, e_th, e_ph components)
      // (v×B)_r  = v_th*B_ph - v_ph*B_th
      // (v×B)_th = v_ph*B_r  - v_r*B_ph
      // (v×B)_ph = v_r*B_th  - v_th*B_r
      const ExB_r  = vth*bph - vph*bth;
      const ExB_th = vph*br  - vr*bph;
      const ExB_ph = vr*bth  - vth*br;

      // ∇×(v×B) — curl in spherical coords (simplified)
      // (∇×F)_r = (1/sinL) ∂(sinL·F_ph)/∂th - (1/sinL) ∂F_th/∂ph
      const ExBr_N  = (Vth[kN]*Bph_[kN] - Vph[kN]*Bth_[kN]) * DR;
      const ExBr_S  = (Vth[kS]*Bph_[kS] - Vph[kS]*Bth_[kS]) * DR;
      const ExBth_E = (Vph[kE]*Br_[kE]  - Vr[kE]*Bph_[kE])  * DR;
      const ExBth_W = (Vph[kW]*Br_[kW]  - Vr[kW]*Bph_[kW])  * DR;

      const curlR  = (ExBr_N*Math.cos(lat(i-1)) - ExBr_S*Math.cos(lat(i+1))) / (2*R*dLat*Math.max(0.01,sinL))
                   - (ExBth_E - ExBth_W) / (2*R*Math.max(0.01,sinL)*dLon);

      const curlTh = (Bph_[kE] - Bph_[kW]) * vphDR / (2*R*Math.max(0.01,sinL)*dLon);

      const curlPh = (br*Math.cos(la) - (Br_[kS] - Br_[kN])/(2*dLat)) * vphDR / R;

      // Laplacian of B (resistive diffusion) — spherical scalar Laplacian
      const lapBr  = (Br_[kN] - 2*br + Br_[kS])/(dLat*dLat)
                   + (Br_[kE] - 2*br + Br_[kW])/(dLon*dLon*Math.max(0.01,cosL*cosL));
      const lapBth = (Bth_[kN] - 2*bth + Bth_[kS])/(dLat*dLat)
                   + (Bth_[kE] - 2*bth + Bth_[kW])/(dLon*dLon*Math.max(0.01,cosL*cosL));
      const lapBph = (Bph_[kN] - 2*bph + Bph_[kS])/(dLat*dLat)
                   + (Bph_[kE] - 2*bph + Bph_[kW])/(dLon*dLon*Math.max(0.01,cosL*cosL));

      dBr_[k]  = curlR  + eta * lapBr;
      dBth_[k] = curlTh + eta * lapBth;
      dBph_[k] = curlPh + eta * lapBph;
    }
  }
  // Boundary: poles
  for (let j = 0; j < NLon; j++) {
    dBr_[idx(0,j)] = dBr_[idx(1,j)];
    dBr_[idx(NLat-1,j)] = dBr_[idx(NLat-2,j)];
    dBth_[idx(0,j)] = 0; dBth_[idx(NLat-1,j)] = 0;
    dBph_[idx(0,j)] = 0; dBph_[idx(NLat-1,j)] = 0;
  }
}

// ── RK4 integrator ──────────────────────────────────────────
let simTime = 0;
let rk4Count = 0;
let params = { DR:1.0, eta:0.02, conv:1.0, buoy:1.0, dt:0.5, A_temp:1.5 };

function rk4Step() {
  const dt = params.dt * 0.001; // scaled
  const eta = params.eta;
  const DR  = params.DR;
  const conv= params.conv;

  // k1
  computeDerivatives(Br, Bth, Bph, dBr1, dBth1, dBph1, eta, DR, conv);

  // k2 — advance by dt/2
  const Br2=new Float64Array(N), Bth2=new Float64Array(N), Bph2=new Float64Array(N);
  for(let k=0;k<N;k++){Br2[k]=Br[k]+0.5*dt*dBr1[k]; Bth2[k]=Bth[k]+0.5*dt*dBth1[k]; Bph2[k]=Bph[k]+0.5*dt*dBph1[k];}
  computeDerivatives(Br2,Bth2,Bph2,dBr2,dBth2,dBph2,eta,DR,conv);

  // k3
  const Br3=new Float64Array(N), Bth3=new Float64Array(N), Bph3=new Float64Array(N);
  for(let k=0;k<N;k++){Br3[k]=Br[k]+0.5*dt*dBr2[k]; Bth3[k]=Bth[k]+0.5*dt*dBth2[k]; Bph3[k]=Bph[k]+0.5*dt*dBph2[k];}
  computeDerivatives(Br3,Bth3,Bph3,dBr3,dBth3,dBph3,eta,DR,conv);

  // k4
  const Br4=new Float64Array(N), Bth4=new Float64Array(N), Bph4=new Float64Array(N);
  for(let k=0;k<N;k++){Br4[k]=Br[k]+dt*dBr3[k]; Bth4[k]=Bth[k]+dt*dBth3[k]; Bph4[k]=Bph[k]+dt*dBph3[k];}
  computeDerivatives(Br4,Bth4,Bph4,dBr4,dBth4,dBph4,eta,DR,conv);

  // Combine + Parker buoyancy (flux tube rise: high |B| → positive Vr)
  const buoy = params.buoy;
  for(let k=0;k<N;k++){
    Br[k]  += (dt/6)*(dBr1[k]  + 2*dBr2[k]  + 2*dBr3[k]  + dBr4[k]);
    Bth[k] += (dt/6)*(dBth1[k] + 2*dBth2[k] + 2*dBth3[k] + dBth4[k]);
    Bph[k] += (dt/6)*(dBph1[k] + 2*dBph2[k] + 2*dBph3[k] + dBph4[k]);

    // Parker magnetic buoyancy: radial velocity proportional to |B|²
    const Bmag2 = Br[k]*Br[k] + Bth[k]*Bth[k] + Bph[k]*Bph[k];
    Vr[k] += buoy * 0.0002 * Bmag2 * dt;
    Vr[k] *= 0.995; // damping

    // Clamp for stability
    Br[k]  = Math.max(-8, Math.min(8, Br[k]));
    Bth[k] = Math.max(-8, Math.min(8, Bth[k]));
    Bph[k] = Math.max(-8, Math.min(8, Bph[k]));
  }

  // Slowly add noise to represent convective turbulence
  if (conv > 0.1 && Math.random() < 0.02) {
    const ki = Math.floor(1 + Math.random()*(NLat-2));
    const kj = Math.floor(Math.random()*NLon);
    const k  = idx(ki,kj);
    Bph[k] += conv * (Math.random()-0.5) * 0.08;
    Bth[k] += conv * (Math.random()-0.5) * 0.04;
  }

  simTime += params.dt * 0.1;
  rk4Count++;
}

// ═══════════════════════════════════════════════════════════
//  THREE.JS OBJECTS
// ═══════════════════════════════════════════════════════════

// ── Magnetic texture on sphere ───────────────────────────────
const TEX_W = NLon, TEX_H = NLat;
const texData = new Uint8Array(TEX_W * TEX_H * 4);
const magTex = new THREE.DataTexture(texData, TEX_W, TEX_H, THREE.RGBAFormat);
magTex.needsUpdate = true;

function temperatureToRGB(b, maxB) {
  // Bipolar magnetogram color: blue=negative, black=neutral, red/yellow=positive
  const t = b / (maxB + 0.001);
  if (t > 0) {
    // Positive: black→red→yellow
    const s = Math.min(1, t);
    return [
      Math.round(255 * Math.sqrt(s)),
      Math.round(255 * s * s * s),
      0,
      255
    ];
  } else {
    // Negative: black→blue→cyan
    const s = Math.min(1, -t);
    return [
      0,
      Math.round(255 * s * s * s),
      Math.round(255 * Math.sqrt(s)),
      255
    ];
  }
}

function updateMagTexture() {
  let maxB = 0.1;
  for(let k=0;k<N;k++) maxB = Math.max(maxB, Math.abs(Br[k]));

  for (let i = 0; i < NLat; i++) {
    for (let j = 0; j < NLon; j++) {
      const k = idx(i,j);
      const [r,g,b,a] = temperatureToRGB(Br[k], maxB);
      const pi = ((NLat-1-i)*NLon + j) * 4; // flip V
      texData[pi]   = r;
      texData[pi+1] = g;
      texData[pi+2] = b;
      texData[pi+3] = a;
    }
  }
  magTex.needsUpdate = true;
}
updateMagTexture();

// Photosphere sphere with mag texture
const photoGeo = new THREE.SphereGeometry(1.0, 128, 64);
const photoMat = new THREE.MeshStandardMaterial({
  map: magTex,
  emissiveMap: magTex,
  emissive: new THREE.Color(0.6, 0.25, 0.0),
  emissiveIntensity: 0.5,
  roughness: 0.95,
  metalness: 0.0,
});
const photoMesh = new THREE.Mesh(photoGeo, photoMat);
scene.add(photoMesh);

// Chromosphere shell
const chromMat = new THREE.MeshStandardMaterial({
  color: 0xff7722, emissive: 0xff4400, emissiveIntensity: 0.5,
  transparent: true, opacity: 0.12, side: THREE.FrontSide, depthWrite: false,
});
scene.add(new THREE.Mesh(new THREE.SphereGeometry(1.05, 48, 48), chromMat));

// Transition region
scene.add(new THREE.Mesh(new THREE.SphereGeometry(1.13, 48, 48),
  new THREE.MeshStandardMaterial({
    color: 0xffe066, emissive: 0xffaa44, emissiveIntensity: 0.3,
    transparent: true, opacity: 0.06, side: THREE.FrontSide, depthWrite: false,
  })
));

// Corona glow
const coronaMat = new THREE.MeshStandardMaterial({
  color: 0xaaddff, emissive: 0x4488ff, emissiveIntensity: 0.25,
  transparent: true, opacity: 0.05, side: THREE.BackSide, depthWrite: false,
});
const coronaMesh = new THREE.Mesh(new THREE.SphereGeometry(1.55, 48, 48), coronaMat);
scene.add(coronaMesh);

// Lighting
const sunLight = new THREE.PointLight(0xff9944, 3.5, 40);
scene.add(sunLight);
const ambLight = new THREE.AmbientLight(0x0a0810, 1);
scene.add(ambLight);

// ── Field Lines (dynamically updated from B grid) ────────────
const FL_COUNT = 32;
const FL_STEPS = 80;
const fieldLines = [];
const flGroup = new THREE.Group();
scene.add(flGroup);

function makeFieldLine(lat0, lon0) {
  const pts = [];
  let la = lat0, lo = lon0;
  let r = 1.02;

  for (let s = 0; s < FL_STEPS; s++) {
    const x = r * Math.cos(la) * Math.cos(lo);
    const y = r * Math.sin(la);
    const z = r * Math.cos(la) * Math.sin(lo);
    pts.push(new THREE.Vector3(x, y, z));

    // Sample field at current position
    const gi = Math.round((la/Math.PI + 0.5) * (NLat-1));
    const gj = Math.round((lo / (2*Math.PI)) * NLon) % NLon;
    const k  = idx(Math.max(0,Math.min(NLat-1,gi)), gj);
    const br = Br[k], bth = Bth[k], bph = Bph[k];
    const bmag = Math.sqrt(br*br+bth*bth+bph*bph)+0.001;

    // Step along field direction
    const step = 0.04;
    la += step * bth / bmag;
    lo += step * bph / (bmag * Math.max(0.05, Math.cos(la)));
    r  += step * br  / bmag * 0.3;
    r   = Math.max(0.99, Math.min(2.5, r));
  }
  return pts;
}

for (let fl = 0; fl < FL_COUNT; fl++) {
  const la = (Math.random()-0.5) * Math.PI * 0.8;
  const lo = (fl / FL_COUNT) * Math.PI * 2;
  const geo = new THREE.BufferGeometry().setFromPoints(makeFieldLine(la, lo));
  const polarity = Br[idx(Math.round((la/Math.PI+0.5)*(NLat-1)), Math.round((lo/(2*Math.PI))*NLon)%NLon)];
  const col = polarity > 0 ? 0xff5522 : 0x4488ff;
  const mat = new THREE.LineBasicMaterial({ color: col, transparent: true, opacity: 0.5 });
  const line = new THREE.Line(geo, mat);
  flGroup.add(line);
  fieldLines.push({ line, la, lo });
}

// ── Flux Tubes (Parker instability — rising magnetic structures) ──
const ftGroup = new THREE.Group();
scene.add(ftGroup);
const fluxTubes = [];

function spawnFluxTube() {
  // Find a high-|B| location on the grid
  let maxK = 0, maxBmag = 0;
  for (let k = 0; k < N; k++) {
    const bm = Math.abs(Br[k]);
    if (bm > maxBmag && Math.random() < 0.1) { maxBmag = bm; maxK = k; }
  }
  const i = Math.floor(maxK / NLon), j = maxK % NLon;
  const la = lat(i), lo = lon(j);
  const r0 = 1.05;

  // Create a tube as a small toroid path
  const pts = [];
  const segments = 40;
  const tubeRadius = 0.12 + Math.random() * 0.08;
  for (let s = 0; s <= segments; s++) {
    const phi = (s / segments) * Math.PI * 2;
    const x = (r0 + tubeRadius * Math.cos(phi)) * Math.cos(la) * Math.cos(lo + tubeRadius * Math.sin(phi) * 0.4);
    const y = (r0 + tubeRadius * Math.cos(phi)) * Math.sin(la);
    const z = (r0 + tubeRadius * Math.cos(phi)) * Math.cos(la) * Math.sin(lo + tubeRadius * Math.sin(phi) * 0.4);
    pts.push(new THREE.Vector3(x, y, z));
  }
  const geo = new THREE.BufferGeometry().setFromPoints(pts);
  const mat = new THREE.LineBasicMaterial({ color: 0xffcc44, transparent: true, opacity: 0.8, linewidth: 1 });
  const obj = new THREE.Line(geo, mat);
  ftGroup.add(obj);

  fluxTubes.push({ obj, la, lo, r: r0, life: 1.0, rise: 0.002 + Math.random()*0.003 });
}

// ── Plasma flow particles ─────────────────────────────────────
const pfGroup = new THREE.Group();
scene.add(pfGroup);
const plasmaParticles = [];
const PF_COUNT = 180;

for (let p = 0; p < PF_COUNT; p++) {
  const la = (Math.random()-0.5)*Math.PI*0.95;
  const lo = Math.random()*Math.PI*2;
  const r  = 1.02 + Math.random()*0.6;
  const geo = new THREE.SphereGeometry(0.009, 4, 4);
  const mat = new THREE.MeshBasicMaterial({ color: 0x88ccff, transparent: true, opacity: 0.7 });
  const mesh = new THREE.Mesh(geo, mat);
  pfGroup.add(mesh);
  plasmaParticles.push({ mesh, la, lo, r, speed: 0.003+Math.random()*0.004 });
}

// ═══════════════════════════════════════════════════════════
//  HELIOSPHERIC CURRENT SHEET (HCS) — "Ballerina Skirt"
//  The HCS is the vast warped surface where B_r changes sign.
//  It separates the heliosphere into magnetic polarity sectors.
//  Modeled using the Schulz (1973) / Hoeksema wavy HCS:
//    θ_HCS(φ,t) = π/2 - α·sin(n·φ - Ω_rot·t)
//  where α = tilt angle, n = sector number/2
// ═══════════════════════════════════════════════════════════

const hcsGroup  = new THREE.Group(); scene.add(hcsGroup);
const psGroup   = new THREE.Group(); scene.add(psGroup);   // Parker spiral
const sbGroup   = new THREE.Group(); scene.add(sbGroup);   // Sector boundaries / CIR
const cirGroup  = new THREE.Group(); scene.add(cirGroup);  // CIR flash events

// HCS parameters (driven by sliders later)
const hcsParams = { tilt: 25, sectors: 2, vsw: 450 };

// ── HCS surface mesh ──────────────────────────────────────────
// Parametric surface: for each (r, φ) compute the warped latitude
// then place a vertex there. The result is the famous ballerina skirt.

const HCS_R_STEPS  = 60;  // radial steps from 1.2 to 5 R☉
const HCS_PHI_STEPS = 180; // azimuthal resolution
const HCS_R_MIN = 1.22, HCS_R_MAX = 5.0;

const hcsGeo = new THREE.BufferGeometry();
const hcsPosArr   = new Float32Array(HCS_R_STEPS * HCS_PHI_STEPS * 3);
const hcsColorArr = new Float32Array(HCS_R_STEPS * HCS_PHI_STEPS * 3);
hcsGeo.setAttribute('position', new THREE.BufferAttribute(hcsPosArr, 3));
hcsGeo.setAttribute('color',    new THREE.BufferAttribute(hcsColorArr, 3));

// Build index buffer for triangle strip across (r, phi) grid
const hcsIdx = [];
for (let ri = 0; ri < HCS_R_STEPS-1; ri++) {
  for (let pi = 0; pi < HCS_PHI_STEPS-1; pi++) {
    const a = ri*HCS_PHI_STEPS + pi;
    const b = a + 1;
    const c = a + HCS_PHI_STEPS;
    const d = c + 1;
    hcsIdx.push(a,c,b, b,c,d);
  }
}
hcsGeo.setIndex(hcsIdx);
const hcsMat = new THREE.MeshBasicMaterial({
  vertexColors: true,
  transparent: true,
  opacity: 0.18,
  side: THREE.DoubleSide,
  depthWrite: false,
});
const hcsMesh = new THREE.Mesh(hcsGeo, hcsMat);
hcsGroup.add(hcsMesh);

// HCS edge wireframe for the "skirt hem" effect
const hcsEdgeGeo  = new THREE.BufferGeometry();
const hcsEdgePts  = new Float32Array(HCS_PHI_STEPS * 3);
hcsEdgeGeo.setAttribute('position', new THREE.BufferAttribute(hcsEdgePts, 3));
const hcsEdgeMat  = new THREE.LineBasicMaterial({ color:0xffcc00, transparent:true, opacity:0.7 });
const hcsEdgeLine = new THREE.LineLoop(hcsEdgeGeo, hcsEdgeMat);
hcsGroup.add(hcsEdgeLine);

let hcsPhaseOffset = 0; // accumulates with sim time for rotation

function updateHCS(phaseOffset) {
  const tiltRad = hcsParams.tilt * Math.PI / 180;
  const n       = hcsParams.sectors / 2; // wave number (2 sectors = 1 full wave)
  const pos     = hcsGeo.attributes.position.array;
  const col     = hcsGeo.attributes.color.array;

  for (let ri = 0; ri < HCS_R_STEPS; ri++) {
    const r = HCS_R_MIN + (ri / (HCS_R_STEPS-1)) * (HCS_R_MAX - HCS_R_MIN);
    // Parker delay: wave crests lag at larger r due to finite wind travel time
    const travelDelay = (r - HCS_R_MIN) / (hcsParams.vsw * 0.0001 + 0.1);

    for (let pi = 0; pi < HCS_PHI_STEPS; pi++) {
      const phi = (pi / HCS_PHI_STEPS) * Math.PI * 2;

      // Wavy HCS latitude: θ_HCS = π/2 + α·sin(n·φ - ωt - delay)
      // Second harmonic for solar-max complexity
      const waveArg = n * phi - phaseOffset - travelDelay * 0.05;
      const thetaHCS = Math.PI/2
        + tiltRad * Math.sin(waveArg)
        + tiltRad * 0.3 * Math.sin(2*waveArg + 0.5); // harmonic warping

      const sinT = Math.sin(thetaHCS), cosT = Math.cos(thetaHCS);
      const sinP = Math.sin(phi),      cosP = Math.cos(phi);

      const x = r * sinT * cosP;
      const y = r * cosT;
      const z = r * sinT * sinP;

      const v = ri*HCS_PHI_STEPS + pi;
      pos[v*3]   = x;
      pos[v*3+1] = y;
      pos[v*3+2] = z;

      // Color: gradient gold→amber by radius, bright at inner edge
      const fade = 1 - ri/(HCS_R_STEPS-1);
      col[v*3]   = 0.7 + fade*0.3;
      col[v*3+1] = 0.45 + fade*0.2;
      col[v*3+2] = 0.0;
    }
  }

  // Outer edge ring (r = HCS_R_MAX) — the skirt hem
  const outerRi = HCS_R_STEPS - 1;
  const r = HCS_R_MAX;
  const edgePos = hcsEdgeGeo.attributes.position.array;
  for (let pi = 0; pi < HCS_PHI_STEPS; pi++) {
    const phi = (pi / HCS_PHI_STEPS) * Math.PI * 2;
    const travelDelay = (r - HCS_R_MIN) / (hcsParams.vsw * 0.0001 + 0.1);
    const waveArg = n * phi - phaseOffset - travelDelay * 0.05;
    const thetaHCS = Math.PI/2
      + tiltRad * Math.sin(waveArg)
      + tiltRad * 0.3 * Math.sin(2*waveArg + 0.5);
    edgePos[pi*3]   = r * Math.sin(thetaHCS) * Math.cos(phi);
    edgePos[pi*3+1] = r * Math.cos(thetaHCS);
    edgePos[pi*3+2] = r * Math.sin(thetaHCS) * Math.sin(phi);
  }

  hcsGeo.attributes.position.needsUpdate = true;
  hcsGeo.attributes.color.needsUpdate    = true;
  hcsEdgeGeo.attributes.position.needsUpdate = true;
  hcsGeo.computeVertexNormals();
}
updateHCS(0);

// ── Parker Spiral IMF lines ───────────────────────────────────
// Beyond the Alfvén point, the frozen-in field winds into an
// Archimedean spiral: B_φ/B_r = -Ω_sun·r·sinθ / V_sw
// Each spiral arm traces a constant-longitude footpoint.

const PS_COUNT  = 16;   // number of spiral arms
const PS_STEPS  = 80;   // points per arm
const PS_R_MAX  = 5.2;
const parkerSpirals = [];

function buildParkerSpiral(phi0, polarity) {
  const pts = [];
  const Omega = 2.87e-6; // solar rotation rad/s (normalized)
  for (let s = 0; s <= PS_STEPS; s++) {
    const r = 1.3 + (s / PS_STEPS) * (PS_R_MAX - 1.3);
    // Archimedean spiral: φ(r) = φ0 - (Ω/Vsw)·(r - r0)
    // Using normalized units: factor ~ 0.8 gives realistic winding
    const windFactor = 0.9 / (hcsParams.vsw / 450);
    const phi = phi0 - windFactor * (r - 1.3);
    // Latitude: slight inclination following HCS tilt
    const tiltRad = hcsParams.tilt * Math.PI / 180;
    const la = tiltRad * 0.15 * Math.sin(phi0 * (hcsParams.sectors/2));
    const x = r * Math.cos(la) * Math.cos(phi);
    const y = r * Math.sin(la);
    const z = r * Math.cos(la) * Math.sin(phi);
    pts.push(new THREE.Vector3(x,y,z));
  }
  return pts;
}

for (let ps = 0; ps < PS_COUNT; ps++) {
  const phi0  = (ps / PS_COUNT) * Math.PI * 2;
  const n     = hcsParams.sectors / 2;
  // Determine polarity sector for this arm
  const pol   = Math.sin(n * phi0) > 0 ? 1 : -1;
  const color = pol > 0 ? 0xff6644 : 0x4488ff;
  const pts   = buildParkerSpiral(phi0, pol);
  const geo   = new THREE.BufferGeometry().setFromPoints(pts);
  const mat   = new THREE.LineBasicMaterial({ color, transparent:true, opacity:0.35 });
  const line  = new THREE.Line(geo, mat);
  psGroup.add(line);
  parkerSpirals.push({ line, phi0, pol });
}

// ── Sector Boundary Lines (where B_r = 0 — the HCS intersection) ──
// At each boundary, a CIR (co-rotating interaction region) forms
// where fast and slow solar wind streams collide → glowing shock.

const SB_COUNT  = hcsParams.sectors; // one boundary per sector
const SB_STEPS  = 60;
const sectorBoundaries = [];

function buildSectorBoundary(phi0) {
  const pts = [];
  for (let s = 0; s <= SB_STEPS; s++) {
    const r = 1.2 + (s/SB_STEPS) * (PS_R_MAX - 1.2);
    const tiltRad = hcsParams.tilt * Math.PI / 180;
    const windFactor = 0.9 / (hcsParams.vsw / 450);
    const phi = phi0 - windFactor * (r - 1.2) * 0.5;
    const la  = tiltRad * Math.sin(phi0 * hcsParams.sectors/2 + Math.PI/2) * 0.2;
    pts.push(new THREE.Vector3(
      r * Math.cos(la) * Math.cos(phi),
      r * Math.sin(la),
      r * Math.cos(la) * Math.sin(phi)
    ));
  }
  return pts;
}

function rebuildSectorBoundaries() {
  sbGroup.clear();
  sectorBoundaries.length = 0;
  for (let sb = 0; sb < hcsParams.sectors; sb++) {
    const phi0 = (sb / hcsParams.sectors) * Math.PI * 2;
    const pts  = buildSectorBoundary(phi0);
    const geo  = new THREE.BufferGeometry().setFromPoints(pts);
    // Hot pink CIR shock line
    const mat  = new THREE.LineBasicMaterial({ color:0xff44aa, transparent:true, opacity:0.65 });
    const line = new THREE.Line(geo, mat);
    sbGroup.add(line);
    sectorBoundaries.push({ line, phi0 });

    // CIR glow dots along boundary
    for (let d = 2; d < SB_STEPS; d += 8) {
      const p = pts[d];
      const dg = new THREE.SphereGeometry(0.025, 4, 4);
      const dm = new THREE.MeshBasicMaterial({ color:0xff88cc, transparent:true, opacity:0.5 });
      const dot = new THREE.Mesh(dg, dm);
      dot.position.copy(p);
      sbGroup.add(dot);
    }
  }
}
