euvLabel.textContent = EUV_CHANNELS[2].nm + ' · ' + EUV_CHANNELS[2].desc;
document.body.appendChild(euvLabel);

// ═══════════════════════════════════════════════════════════
//  PROMINENCES — magnetic flux rope arches
//  Modeled as parametric Bézier arches anchored at high-|B|
//  footpoints. Two types:
//  · Quiescent: slow-rise, cool H-alpha plasma (T~8000K)
//  · Eruptive: fast, triggered by flare events
// ═══════════════════════════════════════════════════════════

const promGroup = new THREE.Group(); scene.add(promGroup);
const prominences = [];

function spawnProminence(forced, eruptive) {
  // Find footpoint: high |Br| site on grid
  let bestK=0, bestB=0;
  for(let k=0;k<N;k++){
    const bm = Math.abs(Br[k]) + (Math.random()<0.1 ? Math.random()*2 : 0);
    if(bm > bestB){ bestB=bm; bestK=k; }
  }
  const fi = Math.floor(bestK/NLon), fj = bestK%NLon;
  const fla = lat(fi), flo = lon(fj);
  const fla2 = fla + (Math.random()-0.5)*0.3;
  const flo2 = flo + (Math.random()-0.5)*0.3;

  const HEIGHT = (0.2 + Math.random()*0.4) * surfParams.promH;
  const PTS    = 40;
  const pts    = [];

  for(let s=0; s<=PTS; s++){
    const t = s/PTS;
    // Bézier: two footpoints + apex
    const la = fla*(1-t) + fla2*t + Math.sin(t*Math.PI)*HEIGHT*0.3;
    const lo = flo*(1-t) + flo2*t;
    const r  = 1.01 + Math.sin(t*Math.PI)*HEIGHT;
    // Add sinuous instability
    const wavy = Math.sin(t*Math.PI*4 + shaderTime*2) * HEIGHT * 0.04;
    pts.push(new THREE.Vector3(
      (r+wavy)*Math.cos(la)*Math.cos(lo),
      (r+wavy)*Math.sin(la),
      (r+wavy)*Math.cos(la)*Math.sin(lo)
    ));
  }

  const geo = new THREE.BufferGeometry().setFromPoints(pts);
  const hue = eruptive ? 0xff3300 : 0xff6688; // orange-red if eruptive, pink if quiescent
  const mat = new THREE.LineBasicMaterial({ color:hue, transparent:true, opacity: eruptive?0.95:0.7 });
  const line = new THREE.Line(geo, mat);
  promGroup.add(line);

  // Plasma blobs along arch
  const blobs = [];
  for(let b=0;b<5;b++){
    const bg = new THREE.SphereGeometry(0.012 + Math.random()*0.01, 5, 5);
    const bm = new THREE.MeshBasicMaterial({ color:eruptive?0xff6600:0xff4488, transparent:true, opacity:0.8 });
    const blobMesh = new THREE.Mesh(bg, bm);
    promGroup.add(blobMesh);
    blobs.push({ mesh:blobMesh, t:b/4, speed:0.003+Math.random()*0.005, dir:Math.random()>0.5?1:-1 });
  }

  prominences.push({
    line, blobs, pts,
    life: eruptive ? 0.4 : 1.0,
    decay: eruptive ? 0.005 : 0.0015,
    eruptive,
    riseRate: eruptive ? 0.004 : 0.0002,
    riseAccum: 0,
    fla, flo, HEIGHT,
  });
}

// Seed initial prominences
for(let p=0;p<3;p++) spawnProminence(true, false);

// ═══════════════════════════════════════════════════════════
//  HELMET STREAMERS — closed coronal structures
//  Form above active regions where field loops are large.
//  Visible in white-light coronagraph. 
//  Modeled as elongated teardrop shapes.
// ═══════════════════════════════════════════════════════════

const helmGroup = new THREE.Group(); scene.add(helmGroup);

function buildHelmetStreamer(la, lo, height) {
  const pts = [];
  const SIDES = 2;
  for(let s=0; s<=50; s++){
    const t = s/50;
    // Left leg
    const r = 1.05 + t * height;
    const spread = t * 0.3 * (1 - t*0.5);
    pts.push(new THREE.Vector3(
      r*Math.cos(la+spread)*Math.cos(lo), r*Math.sin(la+spread), r*Math.cos(la+spread)*Math.sin(lo)
    ));
  }
  for(let s=50; s>=0; s--){
    const t = s/50;
    const r = 1.05 + t * height;
    const spread = t * 0.3 * (1 - t*0.5);
    pts.push(new THREE.Vector3(
      r*Math.cos(la-spread)*Math.cos(lo), r*Math.sin(la-spread), r*Math.cos(la-spread)*Math.sin(lo)
    ));
  }
  const geo = new THREE.BufferGeometry().setFromPoints(pts);
  const mat = new THREE.LineBasicMaterial({ color:0xffcc88, transparent:true, opacity:0.25 });
  return new THREE.Line(geo, mat);
}

// Create initial helmet streamers from high-B locations
function buildHelmets() {
  helmGroup.clear();
  let sites = [];
  for(let i=2;i<NLat-2;i++) for(let j=0;j<NLon;j++){
    const k=idx(i,j);
    if(Math.abs(Br[k]) > 2.5) sites.push({i,j,b:Math.abs(Br[k])});
  }
  sites.sort((a,b)=>b.b-a.b);
  sites.slice(0,5).forEach(s=>{
    const la=lat(s.i), lo=lon(s.j);
    const h = 0.5 + s.b * 0.15;
    helmGroup.add(buildHelmetStreamer(la, lo, h));
  });
}
buildHelmets();

// ═══════════════════════════════════════════════════════════
//  SLIDER WIRING — all new surface/flare sliders
