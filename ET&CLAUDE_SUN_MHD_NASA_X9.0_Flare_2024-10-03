<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Solar MHD · NASA X9.0 Flare · 2024-10-03</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;700&family=Playfair+Display:ital,wght@0,400;1,400&display=swap');

:root {
  --g: #c8943a;
  --gd: #5a3e18;
  --bg: #020108;
  --pan: rgba(4,2,14,0.94);
  --bor: rgba(200,148,58,0.2);
  --tx: #b8a888;
  --txd: #504030;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--tx);font-family:'IBM Plex Mono',monospace;overflow:hidden;width:100vw;height:100vh;}
#cv{position:fixed;inset:0;}

/* floating panels */
.fp{
  position:fixed;z-index:40;
  background:var(--pan);
  border:1px solid var(--bor);
  backdrop-filter:blur(8px);
  min-width:60px;min-height:32px;
  box-shadow:0 8px 32px rgba(0,0,0,0.6);
}
.fp-bar{
  display:flex;align-items:center;justify-content:space-between;
  padding:5px 10px;
  background:rgba(200,148,58,0.06);
  border-bottom:1px solid var(--bor);
  cursor:move;user-select:none;
  height:26px;
}
.fp-title{font-size:7.5px;letter-spacing:0.28em;text-transform:uppercase;color:var(--g);}
.fp-acts{display:flex;gap:4px;}
.fp-btn{
  width:11px;height:11px;border-radius:50%;border:none;cursor:pointer;
  font-size:0;padding:0;
}
.fp-min{background:#c89a30;}
.fp-close{background:#cc4030;}
.fp-body{overflow:hidden;}
.fp.minimized .fp-body{display:none;}
.fp.minimized{min-height:0;}

/* telemetry cells */
#pan-telem{top:12px;right:12px;width:430px;}
.tcg{display:grid;grid-template-columns:repeat(5,1fr);gap:2px;padding:6px;}
.tc{background:rgba(200,148,58,0.04);border:1px solid rgba(200,148,58,0.1);padding:5px 6px;}
.tc .tl{font-size:5.5px;letter-spacing:0.2em;text-transform:uppercase;color:var(--txd);line-height:1;}
.tc .tv{font-size:12px;font-weight:700;color:var(--g);line-height:1.15;margin-top:2px;}
.tc .tu{font-size:5px;color:#3a2c14;letter-spacing:0.08em;margin-top:1px;}

/* control panel */
#pan-ctrl{top:12px;left:12px;width:268px;}
.sh{font-size:6.5px;letter-spacing:0.28em;text-transform:uppercase;color:var(--g);
  padding:5px 10px 4px;border-bottom:1px solid rgba(200,148,58,0.08);
  background:rgba(200,148,58,0.04);}

/* slim slider rows */
.sr{display:grid;grid-template-columns:90px 1fr;align-items:center;gap:6px;
  padding:3px 10px;border-bottom:1px solid rgba(200,148,58,0.04);}
.sr:hover{background:rgba(200,148,58,0.03);}
.sl-lbl{display:flex;flex-direction:column;}
.sl-lbl .sn{font-size:8px;letter-spacing:0.06em;text-transform:uppercase;color:#7a6844;line-height:1.1;}
.sl-lbl .sv{font-size:10px;font-weight:700;color:var(--g);margin-top:1px;}
.sl-lbl .su{font-size:6px;color:var(--txd);}
input[type=range]{
  -webkit-appearance:none;width:100%;height:1px;
  background:rgba(200,148,58,0.25);outline:none;cursor:pointer;border-radius:1px;
}
input[type=range]::-webkit-slider-thumb{
  -webkit-appearance:none;width:8px;height:8px;
  border-radius:50%;background:var(--g);
  box-shadow:0 0 4px rgba(200,148,58,0.5);cursor:pointer;
}

/* toggle grid */
.tgg{display:grid;grid-template-columns:1fr 1fr 1fr;gap:2px;padding:6px 10px;}
.tb{
  font-family:'IBM Plex Mono',monospace;font-size:7px;letter-spacing:0.06em;
  padding:3px 5px;border:1px solid rgba(200,148,58,0.18);
  background:transparent;color:var(--txd);cursor:pointer;
  text-transform:uppercase;transition:all 0.1s;text-align:left;
  white-space:nowrap;overflow:hidden;pointer-events:all;
}
.tb.on{background:rgba(200,148,58,0.1);border-color:rgba(200,148,58,0.45);color:var(--g);}
.tb::before{content:'';display:inline-block;width:4px;height:4px;border-radius:50%;
  background:currentColor;margin-right:4px;vertical-align:middle;opacity:0.7;}

/* flare section */
.fsec{padding:6px 10px 8px;border-top:1px solid rgba(200,148,58,0.08);}
.frow{display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;}
.flbl{font-size:6.5px;letter-spacing:0.22em;text-transform:uppercase;color:#7a4020;}
#flare-status{font-size:7px;letter-spacing:0.12em;}
.fbar{height:2px;background:rgba(255,80,0,0.1);margin-bottom:6px;border-radius:1px;}
#flare-bar{height:100%;background:linear-gradient(to right,#aa1800,#ffcc00);width:0%;border-radius:1px;transition:width 0.3s;}
#flare-btn{
  font-family:'IBM Plex Mono',monospace;font-size:7.5px;letter-spacing:0.18em;
  padding:5px 0;width:100%;border:1px solid rgba(200,148,58,0.3);
  background:rgba(255,60,0,0.05);color:var(--g);cursor:pointer;
  text-transform:uppercase;transition:all 0.18s;pointer-events:all;
}
#flare-btn:hover{background:rgba(255,80,0,0.14);border-color:rgba(255,80,0,0.5);color:#ff8844;}

/* legend panel */
#pan-leg{bottom:12px;right:12px;width:250px;}
.lg{display:grid;grid-template-columns:1fr 1fr;gap:3px 10px;padding:6px 10px;}
.li{display:flex;align-items:center;gap:5px;font-size:6.5px;letter-spacing:0.08em;
  text-transform:uppercase;color:#5a5040;}
.ls{width:14px;height:2px;flex-shrink:0;border-radius:1px;}
.ld{width:5px;height:5px;border-radius:50%;flex-shrink:0;}

/* layer depth panel */
#pan-lay{bottom:12px;left:12px;width:160px;}
.lai{display:flex;align-items:center;gap:6px;padding:3px 10px;
  opacity:0.28;transition:opacity 0.35s;}
.lai.on{opacity:1;}
.lad{width:4px;height:4px;border-radius:50%;}
.lal{font-size:6.5px;letter-spacing:0.15em;text-transform:uppercase;}

/* title */
#title{position:fixed;top:14px;left:296px;pointer-events:none;z-index:35;}
#title h1{font-family:'Playfair Display',serif;font-style:italic;font-weight:400;
  font-size:15px;letter-spacing:0.03em;color:#f0e0c0;line-height:1;}
#title .sub{font-size:6px;letter-spacing:0.3em;text-transform:uppercase;color:var(--gd);margin-top:3px;}
#title .badge{display:inline-block;margin-top:4px;font-size:6px;letter-spacing:0.18em;
  text-transform:uppercase;background:rgba(255,60,0,0.12);border:1px solid rgba(255,80,0,0.35);
  color:#ff8844;padding:2px 6px;}

/* tooltip */
#tip{position:fixed;pointer-events:none;z-index:60;
  background:rgba(2,1,10,0.96);border:1px solid rgba(200,148,58,0.4);
  padding:8px 12px;max-width:220px;display:none;backdrop-filter:blur(6px);}
#tip .tth{font-size:9px;font-weight:700;color:var(--g);margin-bottom:3px;}
#tip .ttb{font-size:7.5px;color:#8a7a60;line-height:1.5;}
#tip .ttv{font-size:7.5px;color:#b8a070;margin-top:4px;}

/* ticker */
#ticker{position:fixed;bottom:12px;left:175px;right:263px;
  background:var(--pan);border:1px solid rgba(255,80,0,0.2);
  padding:4px 10px;font-size:7px;letter-spacing:0.1em;
  color:#8a6040;z-index:35;pointer-events:none;
  display:flex;align-items:center;gap:8px;overflow:hidden;}
.tk-lbl{color:#ff6622;font-size:6px;letter-spacing:0.22em;text-transform:uppercase;flex-shrink:0;}
#tk-txt{overflow:hidden;white-space:nowrap;}

/* scrollable body */
.fp-body::-webkit-scrollbar{width:2px;}
.fp-body::-webkit-scrollbar-thumb{background:var(--gd);border-radius:1px;}

</style>
</head>
<body>

<div id="cv"></div>

<div id="title">
  <h1>Solar MHD · AR3842</h1>
  <p class="sub">RK4 · Induction · HCS · Alfvén · Flare</p>
  <span class="badge">NASA X9.0 · 2024-10-03 12:08 UT</span>
</div>

<!-- Telemetry panel -->
<div class="fp" id="pan-telem">
  <div class="fp-bar" data-panel="pan-telem">
    <span class="fp-title">Live Telemetry</span>
    <div class="fp-acts">
      <button class="fp-btn fp-min" onclick="minPanel('pan-telem')" title="minimize"></button>
      <button class="fp-btn fp-close" onclick="hidePanel('pan-telem')" title="close"></button>
    </div>
  </div>
  <div class="fp-body">
    <div class="tcg">
      <div class="tc"><div class="tl">Sim Days</div><div class="tv" id="tTime">0</div><div class="tu">solar days</div></div>
      <div class="tc"><div class="tl">Max |B|</div><div class="tv" id="tB">—</div><div class="tu">norm G</div></div>
      <div class="tc"><div class="tl">Helicity</div><div class="tv" id="tH">—</div><div class="tu">A·Wb</div></div>
      <div class="tc"><div class="tl">RK4 Steps</div><div class="tv" id="tStep">0</div><div class="tu">iter</div></div>
      <div class="tc"><div class="tl">Plasma β</div><div class="tv" id="tBeta">—</div><div class="tu">ratio</div></div>
      <div class="tc"><div class="tl">Sonic r_s</div><div class="tv" id="tSonic">—</div><div class="tu">R☉</div></div>
      <div class="tc"><div class="tl">Alfvén r_A</div><div class="tv" id="tAlfven">—</div><div class="tu">R☉</div></div>
      <div class="tc"><div class="tl">Sound Spd</div><div class="tv" id="tCs">—</div><div class="tu">km/s</div></div>
      <div class="tc"><div class="tl">HCS Tilt</div><div class="tv" id="tTilt">25°</div><div class="tu">degrees</div></div>
      <div class="tc"><div class="tl">Parker Ang</div><div class="tv" id="tParker">—</div><div class="tu">@1AU</div></div>
      <div class="tc"><div class="tl">Free Energy</div><div class="tv" id="tWfree">—</div><div class="tu">norm</div></div>
      <div class="tc"><div class="tl">Flare Sites</div><div class="tv" id="tFsites">0</div><div class="tu">high-J</div></div>
      <div class="tc"><div class="tl">Vorticity</div><div class="tv" id="tVort">—</div><div class="tu">∇×v</div></div>
      <div class="tc"><div class="tl">∇·B err</div><div class="tv" id="tDivB">—</div><div class="tu">solenoid</div></div>
      <div class="tc"><div class="tl">IMF Sectors</div><div class="tv" id="tSector">±1</div><div class="tu">polarity</div></div>
    </div>
  </div>
</div>

<!-- Controls panel -->
<div class="fp" id="pan-ctrl">
  <div class="fp-bar" data-panel="pan-ctrl">
    <span class="fp-title">MHD Controls</span>
    <div class="fp-acts">
      <button class="fp-btn fp-min" onclick="minPanel('pan-ctrl')" title="minimize"></button>
      <button class="fp-btn fp-close" onclick="hidePanel('pan-ctrl')" title="close"></button>
    </div>
  </div>
  <div class="fp-body" style="overflow-y:auto;max-height:calc(100vh - 130px);">
    <div class="sh">MHD Physics</div>
    <div class="sr"><div class="sl-lbl"><span class="sn">Diff. Rotation</span><span class="sv" id="vDR">1.00</span><span class="su">× Ω(λ)</span></div><input type="range" id="slDR" min="0" max="4" step="0.05" value="1.0"></div>
    <div class="sr"><div class="sl-lbl"><span class="sn">Resistivity η</span><span class="sv" id="vEta">0.020</span><span class="su">mag diffus.</span></div><input type="range" id="slEta" min="0.001" max="0.15" step="0.001" value="0.02"></div>
    <div class="sr"><div class="sl-lbl"><span class="sn">Convection</span><span class="sv" id="vConv">1.00</span><span class="su">zone strength</span></div><input type="range" id="slConv" min="0" max="3" step="0.05" value="1.0"></div>
    <div class="sr"><div class="sl-lbl"><span class="sn">Buoyancy</span><span class="sv" id="vBuoy">1.00</span><span class="su">Parker β_mag</span></div><input type="range" id="slBuoy" min="0" max="3" step="0.05" value="1.0"></div>
    <div class="sr"><div class="sl-lbl"><span class="sn">Time Step dt</span><span class="sv" id="vDT">0.50</span><span class="su">RK4 scale</span></div><input type="range" id="slDT" min="0.05" max="2.0" step="0.05" value="0.5"></div>
    <div class="sr"><div class="sl-lbl"><span class="sn">Corona T</span><span class="sv" id="vTemp">1.5</span><span class="su">× 10⁶ K</span></div><input type="range" id="slTemp" min="0.5" max="5.0" step="0.1" value="1.5"></div>
    <div class="sh">Heliospheric</div>
    <div class="sr"><div class="sl-lbl"><span class="sn">HCS Tilt</span><span class="sv" id="vTiltCtrl">25</span><span class="su">° ballerina</span></div><input type="range" id="slTilt" min="2" max="75" step="1" value="25"></div>
    <div class="sr"><div class="sl-lbl"><span class="sn">Sectors</span><span class="sv" id="vSec">2</span><span class="su">IMF polarity</span></div><input type="range" id="slSec" min="2" max="8" step="2" value="2"></div>
    <div class="sr"><div class="sl-lbl"><span class="sn">Wind Speed</span><span class="sv" id="vVsw">450</span><span class="su">km/s @1AU</span></div><input type="range" id="slVsw" min="200" max="900" step="10" value="450"></div>
    <div class="sh">Solar Surface · Spectral</div>
    <div class="sr"><div class="sl-lbl"><span class="sn">EUV λ</span><span class="sv" id="vWave">171</span><span class="su">Å AIA channel</span></div><input type="range" id="slWave" min="0" max="6" step="1" value="2"></div>
    <div class="sr"><div class="sl-lbl"><span class="sn">Sunspot Size</span><span class="sv" id="vSpotR">1.00</span><span class="su">umbra scale</span></div><input type="range" id="slSpotR" min="0.1" max="3.0" step="0.05" value="1.0"></div>
    <div class="sr"><div class="sl-lbl"><span class="sn">Umbra Depth</span><span class="sv" id="vUmbra">0.70</span><span class="su">darkness 0→1</span></div><input type="range" id="slUmbra" min="0.0" max="1.0" step="0.02" value="0.7"></div>
    <div class="sr"><div class="sl-lbl"><span class="sn">Penumbra</span><span class="sv" id="vPen">0.50</span><span class="su">filament ring</span></div><input type="range" id="slPen" min="0.0" max="1.0" step="0.02" value="0.5"></div>
    <div class="sr"><div class="sl-lbl"><span class="sn">Faculae</span><span class="sv" id="vFac">0.60</span><span class="su">bright borders</span></div><input type="range" id="slFac" min="0.0" max="2.0" step="0.05" value="0.6"></div>
    <div class="sr"><div class="sl-lbl"><span class="sn">Granulation</span><span class="sv" id="vGran">1.00</span><span class="su">cell scale</span></div><input type="range" id="slGran" min="0.1" max="3.0" step="0.05" value="1.0"></div>
    <div class="sr"><div class="sl-lbl"><span class="sn">Supergranule</span><span class="sv" id="vSGran">1.00</span><span class="su">network scale</span></div><input type="range" id="slSGran" min="0.0" max="2.0" step="0.05" value="1.0"></div>
    <div class="sr"><div class="sl-lbl"><span class="sn">Spicules</span><span class="sv" id="vSpic">0.50</span><span class="su">limb jets</span></div><input type="range" id="slSpic" min="0.0" max="2.0" step="0.05" value="0.5"></div>
    <div class="sr"><div class="sl-lbl"><span class="sn">Limb Dark</span><span class="sv" id="vLimb">0.60</span><span class="su">exponent u</span></div><input type="range" id="slLimb" min="0.1" max="1.5" step="0.05" value="0.6"></div>
    <div class="sh">Prominences · Flares</div>
    <div class="sr"><div class="sl-lbl"><span class="sn">Prominence H</span><span class="sv" id="vPromH">1.00</span><span class="su">height R☉</span></div><input type="range" id="slPromH" min="0.1" max="3.0" step="0.05" value="1.0"></div>
    <div class="sr"><div class="sl-lbl"><span class="sn">Prom. Density</span><span class="sv" id="vPromD">1.00</span><span class="su">count</span></div><input type="range" id="slPromD" min="0.0" max="3.0" step="0.05" value="1.0"></div>
    <div class="sr"><div class="sl-lbl"><span class="sn">Flare Freq.</span><span class="sv" id="vFlareF">1.00</span><span class="su">spawn rate</span></div><input type="range" id="slFlareF" min="0.0" max="5.0" step="0.1" value="1.0"></div>
    <div class="sr"><div class="sl-lbl"><span class="sn">Particle Count</span><span class="sv" id="vPCount">180</span><span class="su">plasma flow</span></div><input type="range" id="slPCount" min="50" max="600" step="10" value="180"></div>
    <div class="sh">Layer Visibility</div>
    <div class="tgg">
      <button class="tb on" id="tFL"    onclick="tog('FL')">Field Lines</button>
      <button class="tb on" id="tMT"    onclick="tog('MT')">Mag Texture</button>
      <button class="tb on" id="tFT"    onclick="tog('FT')">Flux Tubes</button>
      <button class="tb on" id="tPF"    onclick="tog('PF')">Plasma Flow</button>
      <button class="tb on" id="tHCS"   onclick="tog('HCS')">HCS Sheet</button>
      <button class="tb on" id="tPS"    onclick="tog('PS')">Parker Sprl</button>
      <button class="tb on" id="tSB"    onclick="tog('SB')">CIR Bounds</button>
      <button class="tb on" id="tALF"   onclick="tog('ALF')">Alfvén Rings</button>
      <button class="tb on" id="tWIND"  onclick="tog('WIND')">Wind v(r)</button>
      <button class="tb on" id="tFLARE" onclick="tog('FLARE')">Flare Sites</button>
      <button class="tb on" id="tVORT"  onclick="tog('VORT')">Vorticity</button>
      <button class="tb on" id="tPROM"  onclick="tog('PROM')">Prominences</button>
      <button class="tb on" id="tSPIC"  onclick="tog('SPIC')">Spicules</button>
      <button class="tb on" id="tHELM"  onclick="tog('HELM')">Streamers</button>
      <button class="tb"    id="tPA"    onclick="tog('PA')">⏸ Pause</button>
    </div>
    <div class="fsec">
      <div class="frow"><span class="flbl">Flare Readiness</span><span id="flare-status" style="color:#5a4020;font-size:7px;letter-spacing:0.12em;">MONITORING</span></div>
      <div class="fbar"><div id="flare-bar"></div></div>
      <button id="flare-btn" onclick="triggerFlare()">▶ TRIGGER FLARE</button>
    </div>
  </div>
</div>

<!-- Legend panel -->
<div class="fp" id="pan-leg">
  <div class="fp-bar" data-panel="pan-leg">
    <span class="fp-title">Legend</span>
    <div class="fp-acts">
      <button class="fp-btn fp-min" onclick="minPanel('pan-leg')" title="minimize"></button>
      <button class="fp-btn fp-close" onclick="hidePanel('pan-leg')" title="close"></button>
    </div>
  </div>
  <div class="fp-body">
    <div class="lg">
      <div class="li"><div class="ls" style="background:linear-gradient(to right,#ff4400,#ffcc00)"></div>Pos B_r</div>
      <div class="li"><div class="ls" style="background:linear-gradient(to right,#0033cc,#0066ff)"></div>Neg B_r</div>
      <div class="li"><div class="ls" style="background:#4466bb"></div>Closed field</div>
      <div class="li"><div class="ls" style="background:#88aaff"></div>Open/polar</div>
      <div class="li"><div class="ls" style="background:#ffcc44"></div>Flux tubes</div>
      <div class="li"><div class="ls" style="background:linear-gradient(to right,#cc9900,#ff8800)"></div>HCS skirt</div>
      <div class="li"><div class="ls" style="background:#ff44aa"></div>CIR boundary</div>
      <div class="li"><div class="ls" style="background:#9988ff;opacity:0.7"></div>Parker spiral</div>
      <div class="li"><div class="ld" style="background:#ffcc00"></div>Sonic r_s</div>
      <div class="li"><div class="ld" style="background:#88aaff"></div>Alfvén r_A</div>
      <div class="li"><div class="ls" style="background:#ffaa44"></div>Wind v(r)</div>
      <div class="li"><div class="ld" style="background:#ff2200"></div>Flare site</div>
      <div class="li"><div class="ls" style="background:#ffdd00;opacity:0.65"></div>Vorticity</div>
      <div class="li"><div class="ls" style="background:#ffeecc;opacity:0.3"></div>Sub-Alfvén</div>
      <div class="li"><div class="ls" style="background:#ff6688"></div>Prominence</div>
      <div class="li"><div class="ls" style="background:#88ddff;opacity:0.6"></div>Spicules</div>
      <div class="li"><div class="ls" style="background:#ffcc88;opacity:0.5"></div>Helmet str.</div>
      <div class="li"><div class="ls" style="background:#44aaff;opacity:0.4"></div>EUV corona</div>
    </div>
  </div>
</div>

<!-- Layer depth panel -->
<div class="fp" id="pan-lay">
  <div class="fp-bar" data-panel="pan-lay">
    <span class="fp-title">Depth Layers</span>
    <div class="fp-acts">
      <button class="fp-btn fp-min" onclick="minPanel('pan-lay')" title="minimize"></button>
    </div>
  </div>
  <div class="fp-body" style="padding:4px 0;">
    <div class="lai on" id="ly0"><div class="lad" style="background:#ff5500"></div><span class="lal" style="color:#ff5500">Photosphere</span></div>
    <div class="lai" id="ly1"><div class="lad" style="background:#ff7733"></div><span class="lal" style="color:#ff7733">Chromosphere</span></div>
