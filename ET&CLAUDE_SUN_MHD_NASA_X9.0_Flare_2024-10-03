// ═══════════════════════════════════════════════════════════
//  MAIN LOOP
// ═══════════════════════════════════════════════════════════
let frame=0, fieldUpdateTimer=0, ftTimer=0;
const FIELD_REFRESH = 15; // update field lines every N frames

function animate() {
  requestAnimationFrame(animate);
  frame++;

  // ── Physics step (skip if paused) ──
  if (!vis.PA) {
    rk4Step();
    rk4Step(); // 2 steps per frame for responsiveness
  }

  // ── Camera ──
  camera.position.x = zoom * Math.sin(rotY) * Math.cos(rotX);
  camera.position.y = zoom * Math.sin(rotX);
  camera.position.z = zoom * Math.cos(rotY) * Math.cos(rotX);
  camera.lookAt(0,0,0);

  // ── Differential rotation of visual sphere ──
  // Equator rotates faster — tilt sphere slightly then rotate
  photoMesh.rotation.y += params.DR * 0.0004;
  chromMat.emissiveIntensity = 0.4 + Math.sin(frame*0.017)*0.1;

  // ── Update magnetic texture ──
  if (vis.MT && frame % 3 === 0) updateMagTexture();

  // ── Update field lines ──
  fieldUpdateTimer++;
  if (vis.FL && fieldUpdateTimer >= FIELD_REFRESH) {
    fieldUpdateTimer = 0;
    fieldLines.forEach((fl,idx) => {
      const newPts = makeFieldLine(fl.la, fl.lo);
      const positions = fl.line.geometry.attributes.position;
      if (!positions) return;
      newPts.forEach((p,s) => {
        if (s < FL_STEPS) {
          positions.array[s*3]   = p.x;
          positions.array[s*3+1] = p.y;
          positions.array[s*3+2] = p.z;
        }
      });
      positions.needsUpdate = true;
      fl.line.geometry.computeBoundingSphere();
      // Recolor by local polarity
      const gi = Math.round((fl.la/Math.PI+0.5)*(NLat-1));
      const gj = Math.round((fl.lo/(Math.PI*2))*NLon)%NLon;
      const k  = Math.max(0,Math.min(NLat-1,gi))*NLon+gj;
      fl.line.material.color.setHex(Br[k]>0 ? 0xff5522 : 0x4488ff);
    });
    flGroup.rotation.y = photoMesh.rotation.y; // co-rotate with sun
  }

  // ── Flux tubes ──
  ftTimer++;
  if (vis.FT && ftTimer % 40 === 0 && fluxTubes.length < 12) spawnFluxTube();
  for (let i=fluxTubes.length-1;i>=0;i--) {
    const ft = fluxTubes[i];
    ft.r += ft.rise * params.buoy;
    ft.life -= 0.003;
    ft.obj.scale.setScalar(ft.r / 1.05);
    ft.obj.position.set(
      (ft.r - 1.05)*Math.cos(ft.la)*Math.cos(ft.lo),
      (ft.r - 1.05)*Math.sin(ft.la),
      (ft.r - 1.05)*Math.cos(ft.la)*Math.sin(ft.lo)
    );
    ft.obj.material.opacity = Math.max(0, ft.life * 0.8);
    if (ft.life<=0||ft.r>1.8) { ftGroup.remove(ft.obj); fluxTubes.splice(i,1); }
  }

  // ── Plasma particles (follow B field) ──
  if (vis.PF) {
    plasmaParticles.forEach(p => {
      const gi = Math.max(0,Math.min(NLat-1,Math.round((p.la/Math.PI+0.5)*(NLat-1))));
      const gj = ((Math.round((p.lo/(Math.PI*2))*NLon)%NLon)+NLon)%NLon;
      const k  = gi*NLon+gj;
      const br=Br[k],bth=Bth[k],bph=Bph[k];
      const bmag=Math.sqrt(br*br+bth*bth+bph*bph)+0.001;

      p.la += p.speed * bth/bmag * params.DR;
      p.lo += p.speed * bph/(bmag*Math.max(0.05,Math.cos(p.la)));
      p.r  += p.speed * br/bmag * 0.2;

      if(p.r>2.4||p.r<0.98||Math.abs(p.la)>Math.PI*0.5) {
        p.la=(Math.random()-0.5)*Math.PI*0.9;
        p.lo=Math.random()*Math.PI*2;
        p.r=1.02+Math.random()*0.5;
      }
      p.lo += params.DR * 0.0004; // co-rotate

      const x=p.r*Math.cos(p.la)*Math.cos(p.lo);
      const y=p.r*Math.sin(p.la);
      const z=p.r*Math.cos(p.la)*Math.sin(p.lo);
      p.mesh.position.set(x,y,z);

      // Color by B polarity
      const col = br>0 ? new THREE.Color(1,0.4,0.2) : new THREE.Color(0.3,0.7,1.0);
      p.mesh.material.color.lerp(col, 0.1);
    });
  }

  // ── Alfvén critical point rings pulse ──
  if (vis.ALF) {
    const pulse = 0.5 + 0.5 * Math.sin(frame * 0.04);
    sonicRingMat.opacity  = 0.4 + pulse * 0.35;
    alfvenRingMat.opacity = 0.3 + pulse * 0.25;
    // Drift marker around ring
    const angle = frame * 0.012;
    if (windSolution) {
      const rs = Math.min(windSolution.r_sonic_R, 6.5);
      const ra = Math.min(windSolution.r_alfven_R, 5.0);
      sonicMarker.position.set(rs * Math.cos(angle), 0, rs * Math.sin(angle));
      alfvenMarker.position.set(ra * Math.cos(angle + 1.2), 0, ra * Math.sin(angle + 1.2));
      // Sub-Alfvénic volume shell
      subAlfMesh.scale.setScalar(ra);
    }
  }

  // Update wind solution and critical points every 60 frames
  if (frame % 60 === 0) updateWindSolution();

  // ── Flare preparation ──
  if (frame % 20 === 0) {
    computeCurrentDensity();
    flareEnergy = computeFreeEnergy();
    flareReadiness = Math.min(1, flareSites.length / 15);

    document.getElementById('flare-bar').style.width = (flareReadiness * 100).toFixed(0) + '%';
    if (flareReadiness > 0.7) {
      document.getElementById('flare-status').textContent = 'READY';
      document.getElementById('flare-status').style.color = '#ff2200';
      document.getElementById('flare-btn').style.borderColor = '#ff4400';
      document.getElementById('flare-btn').style.color = '#ff8844';
    } else if (flareReadiness > 0.3) {
      document.getElementById('flare-status').textContent = 'CHARGING';
      document.getElementById('flare-status').style.color = '#ff8800';
    } else {
      document.getElementById('flare-status').textContent = 'MONITORING';
      document.getElementById('flare-status').style.color = '#7a6040';
      document.getElementById('flare-btn').style.borderColor = 'rgba(212,164,76,0.35)';
      document.getElementById('flare-btn').style.color = '#d4a44c';
    }
    document.getElementById('tFsites').textContent = flareSites.length;
    document.getElementById('tWfree').textContent  = flareEnergy.toFixed(3);
  }

  updateFlareMarkers();

  // ── Flare event animation ──
  for (let i=flareEvents.length-1; i>=0; i--) {
    const fe = flareEvents[i];
    fe.life -= fe.decay;
    fe.flash.material.opacity   = Math.max(0, fe.life * 1.2);
    fe.arc.material.opacity     = Math.max(0, fe.life * 0.9);
    const s = 1 + (1 - fe.life) * 5;
    fe.flash.scale.setScalar(s);
    if (fe.life <= 0) {
      flareGroup.remove(fe.flash);
      flareGroup.remove(fe.arc);
      flareEvents.splice(i, 1);
      if (flareEvents.length === 0) {
        document.getElementById('flare-status').textContent = 'POST-FLARE';
        document.getElementById('flare-status').style.color = '#888888';
      }
    }
  }

  // ── HCS rotation & update ──
  // HCS co-rotates with the sun at the same differential-rotation rate
  if (!vis.PA) {
    hcsPhaseOffset += params.DR * 0.0004;
  }

  if (vis.HCS && frame % 4 === 0) {
    updateHCS(hcsPhaseOffset);
    if (frame % 12 === 0) updatePolarityMap(hcsPhaseOffset);
  }

  // Slowly rotate Parker spirals with the sun
  if (vis.PS) {
    psGroup.rotation.y = photoMesh.rotation.y;
  }
  if (vis.SB) {
    sbGroup.rotation.y = photoMesh.rotation.y;
  }

  // ── HCS reconnection events ──
  if (vis.SB) {
    hcsReconTimer++;
    if (hcsReconTimer % 55 === 0 && hcsReconnections.length < 15) {
      spawnHCSReconnection();
    }
    for (let i=hcsReconnections.length-1; i>=0; i--) {
      const rc = hcsReconnections[i];
      rc.life -= rc.decay;
      rc.segs.material.opacity = rc.life;
      rc.dot.material.opacity  = rc.life * 0.8;
      const s = 1 + (1-rc.life) * 2.5;
      rc.segs.scale.setScalar(s);
      if (rc.life <= 0) {
        cirGroup.remove(rc.segs);
        cirGroup.remove(rc.dot);
        hcsReconnections.splice(i,1);
      }
    }
    cirGroup.rotation.y = photoMesh.rotation.y;
  }

  // ── Vorticity tracer animation ──
  if (vis.VORT && frame % 2 === 0) {
    vortParticles.forEach((p, vi) => {
      p.age++;
      // Sample vorticity at current position
      const gi = Math.max(1, Math.min(NLat-2, Math.round((p.la/Math.PI+0.5)*(NLat-1))));
      const gj = ((Math.round((p.lo/(Math.PI*2))*NLon)%NLon)+NLon)%NLon;
      const omega = computeVorticityAt(gi, gj);

      // Advect with velocity + vorticity-driven drift
      const sinL = Math.sin(p.la);
      const vphDR = params.DR * (0.18 - 0.027*sinL*sinL - 0.028*Math.pow(sinL,4));
      p.lo += 0.002 * vphDR + 0.001 * (Math.random()-0.5);
      p.la += 0.0005 * (Math.random()-0.5) * params.conv;

      if (p.age > 200 || Math.abs(p.la) > Math.PI*0.48) {
        p.la = (Math.random()-0.5)*Math.PI*0.8;
        p.lo = Math.random()*Math.PI*2;
        p.age = 0;
      }

      const r = p.r;
      p.mesh.position.set(
        r*Math.cos(p.la)*Math.cos(p.lo),
        r*Math.sin(p.la),
        r*Math.cos(p.la)*Math.sin(p.lo)
      );
      // Intensity proportional to local vorticity
      const intensity = Math.min(1, omega * 5);
      p.mesh.material.opacity = 0.15 + intensity * 0.55;
      p.mesh.material.color.setHSL(0.38 - intensity*0.1, 1, 0.5 + intensity*0.2);
    });
  }

  // ── Telemetry ──
  if (frame%12===0) {
    let maxB=0, helicity=0, divBsum=0, vortSum=0;
    const dLat=Math.PI/(NLat-1), dLon=2*Math.PI/NLon;
    for(let i=1;i<NLat-1;i++){
      for(let j=0;j<NLon;j++){
        const k=idx(i,j);
        const bm=Math.sqrt(Br[k]*Br[k]+Bth[k]*Bth[k]+Bph[k]*Bph[k]);
        if(bm>maxB)maxB=bm;
        helicity+=Br[k]*Vr[k];
        // ∇·B = ∂Br/∂r + 2Br/r (shell approx) — should be ~0
        const kN=idx(i-1,j),kS=idx(i+1,j);
        const divB = (Br[kN]-Br[kS])/(2*dLat) + 2*Br[k];
        divBsum += Math.abs(divB);
        vortSum += computeVorticityAt(i,j);
      }
    }
    const beta = (1.2/(maxB*maxB+0.01)).toFixed(2);
    const parkerAngle = Math.round(Math.atan((2.87e-6 * 1.5e11) / (hcsParams.vsw * 1e3)) * 180/Math.PI);
    document.getElementById('tTime').textContent    = simTime.toFixed(1);
    document.getElementById('tB').textContent       = maxB.toFixed(2);
    document.getElementById('tH').textContent       = (helicity/N).toFixed(3);
    document.getElementById('tStep').textContent    = rk4Count.toLocaleString();
    document.getElementById('tBeta').textContent    = beta;
    document.getElementById('tTilt').textContent    = hcsParams.tilt + '°';
    document.getElementById('tSector').textContent  = '±' + (hcsParams.sectors/2);
    document.getElementById('tParker').textContent  = parkerAngle + '°';
    document.getElementById('tDivB').textContent    = (divBsum/N).toExponential(1);
    document.getElementById('tVort').textContent    = (vortSum/N).toExponential(1);
    document.getElementById('tFsites').textContent  = flareSites.length;
    document.getElementById('tWfree').textContent   = flareEnergy.toFixed(3);
  }

  // Corona glow pulse
  coronaMesh.material.opacity = 0.04 + Math.sin(frame*0.008)*0.015;

  renderer.render(scene,camera);
}
