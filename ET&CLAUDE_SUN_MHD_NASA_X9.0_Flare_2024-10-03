// ═══════════════════════════════════════════════════════════
//  ALFVÉN CRITICAL POINT & PARKER TRANSONIC WIND SOLUTION
//
//  Parker (1958) showed the solar wind must pass through TWO
//  critical points on its way to infinity:
//
//  1. SONIC POINT r_s: where v_wind = v_sound
//     r_s = GM☉ / (2·c_s²)
//     At T_corona ~ 1.5 MK → c_s ~ 150 km/s → r_s ~ 5–8 R☉
//
//  2. ALFVÉN POINT r_A: where v_wind = v_Alfvén = B/√(μ₀ρ)
//     Below r_A: corona magnetically dominated (sub-Alfvénic)
//     Above r_A: plasma drags field (super-Alfvénic)
//     Parker Solar Probe first crossed r_A in April 2021!
//     r_A ~ 10–20 R☉ depending on solar wind conditions
//
//  We solve Parker's ODE using RK4 outward integration,
//  finding v(r) from 1 R☉ to 5 R☉, then overlay both rings.
// ═══════════════════════════════════════════════════════════

const alfvenGroup = new THREE.Group(); scene.add(alfvenGroup);
const flareGroup  = new THREE.Group(); scene.add(flareGroup);

// ── Solve Parker wind equation via RK4 ─────────────────────
// dv/dr = v · (2c_s²/r - GM/r²) / (v² - c_s²)
// Normalized: GM=1, R☉=1, c_s in units of escape speed

function solveParkerWind(T_MK, B0_norm) {
  // Physical constants (SI, then normalize)
  const GM    = 1.327e20;    // m³/s²
  const R_sun = 6.957e8;     // m
  const kb    = 1.38e-23;
  const mp    = 1.67e-27;
  const mu0   = 4*Math.PI*1e-7;

  const T     = T_MK * 1e6;
  const cs    = Math.sqrt(2 * kb * T / mp);         // sound speed m/s
  const r_s   = GM / (2 * cs * cs);                 // sonic radius m
  const r_s_R = r_s / R_sun;                        // in R☉

  // RK4 integration of Parker ODE in physical units
  // Start just above 1 R☉, integrate outward to ~25 R☉
  const N_steps = 400;
  const r_max   = 25 * R_sun;
  const dr      = (r_max - R_sun * 1.01) / N_steps;

  // dv/dr = v*(2cs²/r - GM/r²) / (v² - cs²)
  function dvdr(r, v) {
    const num = v * (2*cs*cs/r - GM/(r*r));
    const den = v*v - cs*cs;
    if (Math.abs(den) < 1e-6 * cs*cs) return 0; // near critical point
    return num / den;
  }

  // Start below sonic point with approximate initial condition
  // v(r_near) from Parker's analytic approximation near r=1 R☉
  const r0 = R_sun * 1.01;
  // Far-subsonic approximation: v ≈ cs² * r_s/r at r << r_s
  let v = cs * cs * r_s / (r0 * cs) * 0.1;
  v = Math.max(v, 1000); // floor at 1 km/s

  const profile = []; // {r_R: in R☉, v_kms: in km/s, mach: v/cs}
  let r = r0;

  for (let i = 0; i < N_steps; i++) {
    profile.push({
      r_R: r / R_sun,
      v_kms: v / 1e3,
      mach: v / cs
    });

    // RK4
    const k1 = dvdr(r, v);
    const k2 = dvdr(r + dr/2, v + dr*k1/2);
    const k3 = dvdr(r + dr/2, v + dr*k2/2);
    const k4 = dvdr(r + dr, v + dr*k3);
    const dv = (dr/6) * (k1 + 2*k2 + 2*k3 + k4);

    if (!isFinite(dv) || Math.abs(dv) > v * 10) break;
    v += dv;
    r += dr;
    if (v > 2000e3) break; // cap at 2000 km/s
  }

  // Find sonic and Alfvén radii from profile
  let r_sonic_R = r_s_R; // analytic
  let r_alfven_R = 15;   // default
  let alfvenFound = false;

  // ρ(r) ~ ρ0 * (r0/r)² for mass conservation at constant speed (approx)
  // v_A(r) = B0/R☉² * r² / sqrt(mu0 * rho0 * r0² / r²) ... simplified:
  // v_A ~ v_A0 * (r0/r) for dipole field ~ 1/r³, rho ~ 1/r²
  // v_A0 calibrated to B0_norm
  const v_A0 = B0_norm * 200e3; // Alfvén speed at 1 R☉ in m/s

  for (let i = 1; i < profile.length; i++) {
    const p  = profile[i];
    const r_ = p.r_R;
    // Alfvén speed decreases faster than wind speed increases → crossing
    const vA = v_A0 / (r_ * r_); // dipole: B~1/r³, rho~1/r²  → vA~1/r²
    if (!alfvenFound && p.v_kms * 1e3 >= vA) {
      r_alfven_R = r_;
      alfvenFound = true;
    }
  }

  return { profile, r_sonic_R, r_alfven_R, cs_kms: cs/1e3 };
}

