// ═══════════════════════════════════════════════════════════
//  FLARE PREPARATION SYSTEM
//  A real solar flare requires:
//  1. A region of high free magnetic energy (W_free)
//  2. A steep current sheet (high |∇×B| = |J|/μ₀)
//  3. A triggering instability (torus or kink) when twist exceeds threshold
//
//  We pre-compute these quantities each frame on the MHD grid,
//  mark "flare-ready" zones, and hold them ready for ignition.
//  The flare trigger button will detonate stored W_free as:
//    - Impulsive phase: current sheet collapses, X-point forms
//    - Flash phase: thermal energy release, T→10-30 MK
//    - Decay phase: post-flare loops, plasmoid ejection
// ═══════════════════════════════════════════════════════════

const FLARE_THRESHOLD = 3.5;   // |J| threshold for flare-ready marking
const flareSites      = [];    // current flare-ready sites
const flareMarkers    = [];    // visual markers for high-J sites
const flareEvents     = [];    // active flare detonations

// Current density grid J = ∇×B/μ₀ (we store |J| normalized)
const Jmag = new Float32Array(N);

function computeCurrentDensity() {
  const dLat = Math.PI / (NLat-1);
  const dLon = 2*Math.PI / NLon;
  let maxJ = 0.001;

  for (let i=1; i<NLat-1; i++) {
    for (let j=0; j<NLon; j++) {
      const kN = idx(i-1,j), kS = idx(i+1,j);
      const kE = idx(i,j+1), kW = idx(i,j-1);
      const k  = idx(i,j);

      // (∇×B)_r ≈ (∂Bph/∂θ - ∂Bth/∂φ) / r
      const dBphDth = (Bph[kN] - Bph[kS]) / (2*dLat);
      const dBthDph = (Bth[kE] - Bth[kW]) / (2*dLon);
      const Jr = dBphDth - dBthDph;

      // (∇×B)_th ≈ ∂Br/∂φ - ∂Bph/∂r (we approximate ∂r as 0 on shell)
      const Jth = (Br[kE] - Br[kW]) / (2*dLon);

      // (∇×B)_ph ≈ ∂Bth/∂r - ∂Br/∂θ
      const Jph = -(Br[kN] - Br[kS]) / (2*dLat);

      Jmag[k] = Math.sqrt(Jr*Jr + Jth*Jth + Jph*Jph);
      if (Jmag[k] > maxJ) maxJ = Jmag[k];
    }
  }

  // Normalize and find flare-ready sites
  flareSites.length = 0;
  for (let i=1; i<NLat-1; i++) {
    for (let j=0; j<NLon; j++) {
      const k = idx(i,j);
      Jmag[k] /= maxJ;
      if (Jmag[k] > 0.85) {
        flareSites.push({ i, j, k, J: Jmag[k] });
      }
    }
  }
}

// Flare-ready visual markers (pulsing dots on sphere surface)
const flareMarkerPool = [];
const FLARE_POOL_SIZE = 20;
for (let f=0; f<FLARE_POOL_SIZE; f++) {
  const mg  = new THREE.SphereGeometry(0.022, 6, 6);
  const mm  = new THREE.MeshBasicMaterial({ color:0xff2200, transparent:true, opacity:0 });
  const mesh = new THREE.Mesh(mg, mm);
  flareGroup.add(mesh);
  flareMarkerPool.push(mesh);
}

function updateFlareMarkers() {
  flareMarkerPool.forEach((m,i) => {
    if (i < flareSites.length && vis.FLARE) {
      const s  = flareSites[i];
      const la = lat(s.i), lo = lon(s.j);
      const r  = 1.015;
      m.position.set(
        r * Math.cos(la) * Math.cos(lo + photoMesh.rotation.y),
        r * Math.sin(la),
        r * Math.cos(la) * Math.sin(lo + photoMesh.rotation.y)
      );
      const pulse = 0.3 + 0.7 * Math.abs(Math.sin(frame * 0.05 + i));
      m.material.opacity = s.J * pulse * 0.9;
      m.material.color.setHex(s.J > 0.95 ? 0xff0000 : 0xff6600);
    } else {
      m.material.opacity = 0;
    }
  });
}

// Free magnetic energy calculation
// W_free ~ sum of (Br² + Bth² + Bph²) - potential field contribution
// Potential field ~ dipole with amplitude = mean(|Br|)
function computeFreeEnergy() {
  let Wtotal = 0, Wpot = 0;
  let meanBr = 0;
  for (let k=0; k<N; k++) meanBr += Math.abs(Br[k]);
  meanBr /= N;
  for (let k=0; k<N; k++) {
    Wtotal += Br[k]*Br[k] + Bth[k]*Bth[k] + Bph[k]*Bph[k];
    Wpot   += meanBr * meanBr; // potential field proxy
  }
  return Math.max(0, (Wtotal - Wpot) / N);
}

// ── FLARE TRIGGER ────────────────────────────────────────────
let flarePrimed    = false;
let flareEnergy    = 0;
let flareReadiness = 0; // 0–1, shown in UI

window.triggerFlare = function() {
  if (!flarePrimed || flareSites.length === 0) {
    document.getElementById('flare-btn').textContent = 'CHARGING...';
    flarePrimed = true;
    return;
  }
  // Pick highest-J site
  const site = flareSites.reduce((a,b) => a.J > b.J ? a : b);
  const la = lat(site.i), lo = lon(site.j);

  // Inject impulsive energy into field as localized perturbation
  // This will be the seed for the full flare physics in next build
  const radius = 3;
  for (let di=-radius; di<=radius; di++) {
    for (let dj=-radius; dj<=radius; dj++) {
      const ii = Math.max(1, Math.min(NLat-2, site.i+di));
      const jj = site.j + dj;
      const k  = idx(ii, ((jj%NLon)+NLon)%NLon);
      const dist = Math.sqrt(di*di+dj*dj);
      const amp  = flareEnergy * Math.exp(-dist*0.8);
      // Explosive reconnection: collapse current sheet
      Br[k]  *= (1 - amp * 0.4);
      Bph[k] += amp * (Math.random()-0.5) * 2;
      Bth[k] += amp * (Math.random()-0.5) * 2;
    }
  }

  // Spawn visual flare event
  spawnFlareEvent(la, lo);
  flarePrimed = false;
  document.getElementById('flare-btn').textContent = '▶ TRIGGER FLARE EVENT';
  document.getElementById('flare-btn').style.borderColor = 'rgba(212,164,76,0.35)';
};

function spawnFlareEvent(la, lo) {
  // Impulsive flash dome
  const flashGeo = new THREE.SphereGeometry(0.05, 12, 12);
  const flashMat = new THREE.MeshBasicMaterial({ color:0xffffff, transparent:true, opacity:1.0 });
  const flash    = new THREE.Mesh(flashGeo, flashMat);
  const r0 = 1.02;
  flash.position.set(
    r0*Math.cos(la)*Math.cos(lo), r0*Math.sin(la), r0*Math.cos(la)*Math.sin(lo)
  );
  flareGroup.add(flash);

  // Thermal arcade loops — pre-flare loop system that will reconnect
  const arcPts = [];
  for (let s=0; s<=40; s++) {
    const t  = s/40;
    const h  = Math.sin(t*Math.PI) * 0.25;
    const r_ = r0 + h;
    const la2= la + (t-0.5)*0.3;
    arcPts.push(new THREE.Vector3(
      r_*Math.cos(la2)*Math.cos(lo), r_*Math.sin(la2), r_*Math.cos(la2)*Math.sin(lo)
    ));
  }
  const arcGeo = new THREE.BufferGeometry().setFromPoints(arcPts);
  const arcMat = new THREE.LineBasicMaterial({ color:0xff6600, transparent:true, opacity:0.9 });
  const arc    = new THREE.Line(arcGeo, arcMat);
  flareGroup.add(arc);

  flareEvents.push({ flash, arc, life:1.0, decay:0.008, la, lo });
  document.getElementById('flare-status').textContent = 'FLARE ACTIVE';
  document.getElementById('flare-status').style.color = '#ff4400';
}

// ═══════════════════════════════════════════════════════════
//  VORTICITY & DIVERGENCE — fluid dynamics diagnostics
//  ω = ∇×v (rotation of the plasma flow field)
//  ∇·B = 0 (solenoidal condition — should stay near zero)
//  Vorticity tubes form at shear layers between fast/slow
//  rotation bands — these are the seeds of flux tube kinking.
// ═══════════════════════════════════════════════════════════

const vortGroup = new THREE.Group(); scene.add(vortGroup);
const VORT_COUNT = 60;
const vortParticles = [];

// Compute vorticity at grid point
function computeVorticityAt(i, j) {
  const dLat = Math.PI/(NLat-1), dLon = 2*Math.PI/NLon;
  const kN=idx(i-1,j),kS=idx(i+1,j),kE=idx(i,j+1),kW=idx(i,j-1);
  // ω_r = ∂Vph/∂θ - ∂Vth/∂φ (simplified)
  const wr = (Vph[kN]-Vph[kS])/(2*dLat) - (Vth[kE]-Vth[kW])/(2*dLon);
  // ω_th = ∂Vr/∂φ - ∂Vph/∂r (approx, shell)
  const wt = (Vr[kE]-Vr[kW])/(2*dLon);
  // ω_ph = ∂Vth/∂r - ∂Vr/∂θ (approx)
  const wp = -(Vr[kN]-Vr[kS])/(2*dLat);
  return Math.sqrt(wr*wr+wt*wt+wp*wp);
}

// Spawn vorticity tracers as small streamlines at high-shear zones
for (let v=0; v<VORT_COUNT; v++) {
  const la = (Math.random()-0.5)*Math.PI*0.85;
  const lo = Math.random()*Math.PI*2;
  const r  = 1.03 + Math.random()*0.08;
  const geo = new THREE.SphereGeometry(0.007, 4, 4);
  const mat = new THREE.MeshBasicMaterial({ color:0xffdd00, transparent:true, opacity:0.5 });
  const mesh = new THREE.Mesh(geo, mat);
  vortGroup.add(mesh);
  vortParticles.push({ mesh, la, lo, r, trail:[], age:Math.random()*100 });
}

// Vorticity trail lines
const vortTrails = [];
for (let v=0; v<12; v++) {
  const pts = Array(8).fill(0).map(()=>new THREE.Vector3(0,0,0));
