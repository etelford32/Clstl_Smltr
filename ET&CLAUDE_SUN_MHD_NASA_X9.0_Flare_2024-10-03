function wireSlider(id, valId, key, target, fmt, onchange){
  const sl = document.getElementById(id);
  const vl = document.getElementById(valId);
  if(!sl) return;
  sl.addEventListener('input', ()=>{
    const v = parseFloat(sl.value);
    target[key] = v;
    if(vl) vl.textContent = fmt ? fmt(v) : v.toFixed(2);
    sunUniforms['u' + key.charAt(0).toUpperCase() + key.slice(1)] &&
      (sunUniforms['u' + key.charAt(0).toUpperCase() + key.slice(1)].value = v);
    if(onchange) onchange(v);
  });
}

