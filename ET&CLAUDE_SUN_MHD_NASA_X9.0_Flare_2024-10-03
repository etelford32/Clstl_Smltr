// ═══════════════════════════════════════════════════════════
//  UNIFIED SUN SHADER — full spectral pipeline
//  Features:
//  · EUV multi-wavelength LUT (7 AIA channels)
//  · Granulation + supergranulation (2-scale convection)
//  · Sunspot: umbra/penumbra/penumbral filaments
//  · Faculae: bright magnetic network borders
//  · Spicule jets at chromospheric limb
//  · H-alpha chromospheric network (fibrils)
//  · Limb darkening with wavelength-dependent exponent
//  · Flare hot-plasma injection via uFlareMap texture
// ═══════════════════════════════════════════════════════════

const sunUniforms = {
  uMagTex:    { value: magTex },
  uTime:      { value: 0.0 },
  uMaxB:      { value: 4.0 },
  uChannel:   { value: 2 },        // EUV channel
  uSpotR:     { value: 1.0 },
  uUmbra:     { value: 0.70 },
  uPenumbra:  { value: 0.50 },
  uFaculae:   { value: 0.60 },
  uGran:      { value: 1.0 },
  uSGran:     { value: 1.0 },
  uSpicules:  { value: 0.50 },
  uLimb:      { value: 0.60 },
  uFlareHeat: { value: 0.0 },      // 0→1 during flare
  uARLat:     { value: AR_LAT },
  uARLon:     { value: AR_LON },
  uSunRot:    { value: 0.0 },      // cumulative rotation
};

const sunVert = `
  varying vec2 vUv;
  varying vec3 vNorm;
  varying vec3 vView;
  varying vec3 vWorldPos;
  void main() {
    vUv = uv;
    vNorm = normalize(normalMatrix * normal);
    vec4 mv = modelViewMatrix * vec4(position, 1.0);
    vView = normalize(-mv.xyz);
    vWorldPos = position;
    gl_Position = projectionMatrix * mv;
  }
`;

const sunFrag = `
  precision highp float;
  uniform sampler2D uMagTex;
  uniform float uTime;
  uniform float uMaxB;
  uniform int   uChannel;
  uniform float uSpotR;
  uniform float uUmbra;
  uniform float uPenumbra;
  uniform float uFaculae;
  uniform float uGran;
  uniform float uSGran;
  uniform float uSpicules;
  uniform float uLimb;
  uniform float uFlareHeat;
  uniform float uARLat;
  uniform float uARLon;
  uniform float uSunRot;
  varying vec2 vUv;
  varying vec3 vNorm;
  varying vec3 vView;
  varying vec3 vWorldPos;

  // ── NOISE LIBRARY ──────────────────────────────────────────
  float h21(vec2 p){return fract(sin(dot(p,vec2(127.1,311.7)))*43758.5453);}
  float h31(vec3 p){return fract(sin(dot(p,vec3(127.1,311.7,74.7)))*43758.5453);}

  float n2(vec2 p){
    vec2 i=floor(p),f=fract(p);
    f=f*f*(3.0-2.0*f);
    return mix(mix(h21(i),h21(i+vec2(1,0)),f.x),
               mix(h21(i+vec2(0,1)),h21(i+vec2(1,1)),f.x),f.y);
  }

  float fbm2(vec2 p, int oct){
    float v=0.0,a=0.5;
    for(int i=0;i<8;i++){
      if(i>=oct) break;
      v+=a*n2(p); p*=2.1; a*=0.5;
    }
    return v;
  }

  // Voronoi — for granulation cell structure
  vec2 voronoi(vec2 p){
    vec2 b=floor(p), res=vec2(8.0);
    for(int j=-1;j<=1;j++) for(int i=-1;i<=1;i++){
      vec2 g=vec2(float(i),float(j));
      vec2 o=vec2(h21(b+g+vec2(0,100)),h21(b+g+vec2(100,0)));
      o=0.5+0.5*sin(uTime*0.2+6.2831*o);
      float d=length(g+o-fract(p));
      if(d<res.x){res.y=res.x;res.x=d;}
      else if(d<res.y){res.y=d;}
    }
    return res;
  }

  // ── EUV COLOR LUTS ─────────────────────────────────────────
  vec3 lut94(float t){  // Fe XVIII — hot blue-white
    return mix(vec3(0.0,0.0,0.05), mix(vec3(0.1,0.6,1.0),vec3(0.9,1.0,1.0),t*t), t);
  }
  vec3 lut131(float t){ // Fe VIII/XXI — cyan-teal
    return mix(vec3(0.0,0.02,0.04), mix(vec3(0.2,0.7,0.8),vec3(0.8,1.0,1.0),t), t);
  }
  vec3 lut171(float t){ // Fe IX — classic SDO blue
    return mix(vec3(0.0,0.0,0.08), mix(vec3(0.1,0.3,0.85),vec3(0.4,0.6,1.0),t*0.7), t);
  }
  vec3 lut193(float t){ // Fe XII — gold-green
    return mix(vec3(0.05,0.04,0.0), mix(vec3(0.7,0.6,0.1),vec3(1.0,0.95,0.6),t), t);
  }
  vec3 lut211(float t){ // Fe XIV — purple-magenta
    return mix(vec3(0.04,0.0,0.06), mix(vec3(0.6,0.1,0.75),vec3(1.0,0.5,1.0),t), t);
  }
  vec3 lut304(float t){ // He II — orange-red prominence
    return mix(vec3(0.08,0.01,0.0), mix(vec3(0.95,0.25,0.05),vec3(1.0,0.7,0.4),t), t);
  }
  vec3 lutHMI(float br){ // Bipolar magnetogram
    float t=clamp(abs(br),0.0,1.0);
    if(br>0.0) return mix(vec3(0.08,0.02,0.0),mix(vec3(0.85,0.4,0.03),vec3(1.0,0.95,0.4),t),t);
    return mix(vec3(0.01,0.01,0.06),mix(vec3(0.04,0.12,0.65),vec3(0.6,0.8,1.0),t),t);
  }

  // ── GRANULATION ────────────────────────────────────────────
  // Two-scale: granules (~1 Mm) + supergranules (~30 Mm)
  // Modeled as Voronoi cells with FBM interior turbulence
  float granulation(vec2 uv){
    // Granules: small ~28/uv scale
    float gScale = 28.0 * uGran;
    vec2 vr = voronoi(uv * gScale + vec2(uTime*0.08, 0.0));
    float gran = 1.0 - smoothstep(0.0, 0.12, vr.x);        // bright cell centers
    float border = smoothstep(0.08,0.18,vr.x) * (1.0-smoothstep(0.18,0.25,vr.x)); // dark lanes
    float cell = gran * 0.7 + (1.0-border*0.6);

    // Supergranulation network: large cells
    float sgScale = 3.5 * uSGran;
    vec2 svr = voronoi(uv * sgScale + vec2(0.0, uTime*0.02));
    float snet = smoothstep(0.0,0.08,svr.x) * (1.0-smoothstep(0.08,0.15,svr.x));
    float sgran = 1.0 - snet * 0.35; // network is slightly brighter

    return cell * sgran;
  }

  // ── CHROMOSPHERIC NETWORK (H-alpha fibrils) ────────────────
  float chromoNet(vec2 uv, float br){
    // Fibril alignment follows B field direction (approximated)
    float angle = atan(br * 2.0) + uTime * 0.05;
    vec2 rotUv = vec2(uv.x*cos(angle)-uv.y*sin(angle),
                      uv.x*sin(angle)+uv.y*cos(angle));
    float fibrils = n2(rotUv * 40.0 + uTime*0.1) * 0.5
                  + n2(rotUv * 80.0 - uTime*0.07) * 0.3;
    return fibrils;
  }

  // ── SUNSPOT ────────────────────────────────────────────────
  // Given normalized field strength, compute umbra/penumbra/filament
  vec3 sunspot(float strength, float gran){
    // Umbra: darkest core
    float umbStrength = clamp((strength - 0.35) / 0.4, 0.0, 1.0) * uSpotR;
    float umbraDark   = 1.0 - umbStrength * uUmbra;

    // Penumbra: radial filament ring outside umbra
    float penWidth  = 0.25 * uPenumbra;
    float penStart  = 0.35 * uSpotR;
    float penEnd    = penStart + penWidth;
    float penFrac   = smoothstep(penStart, penEnd, strength) *
                      (1.0 - smoothstep(penEnd, penEnd+0.1, strength));
    // Penumbra has radial fibril texture
    float fibril    = 0.6 + 0.4 * n2(vec2(strength * 40.0, gran * 8.0) + uTime*0.15);
    float penDark   = 1.0 - penFrac * 0.45 * fibril;

    // Faculae: bright ring just outside penumbra (strong field + limb effect)
    float facFrac   = smoothstep(penEnd, penEnd+0.05, strength) *
                      (1.0-smoothstep(penEnd+0.05, penEnd+0.12, strength));
    float fac       = 1.0 + facFrac * uFaculae * 0.8;

    return vec3(umbraDark * penDark * fac);
  }

  // ── SPICULES at limb ────────────────────────────────────────
  float spicules(vec2 uv, float limbFrac){
    // Spicules only visible at limb (limbFrac near 0)
    float limbZone = smoothstep(0.12, 0.0, limbFrac);
    if(limbZone < 0.01) return 0.0;
    // Vertical streaks in chromosphere UV
    float spicPhase = uv.x * 180.0 + uTime * 2.0;
    float spic = pow(max(0.0, sin(spicPhase)), 6.0) *
                 n2(uv * vec2(200.0,60.0) + vec2(0.0,uTime*0.5));
    return spic * limbZone * uSpicules;
  }

  // ── MAIN ───────────────────────────────────────────────────
  void main(){
    // Magnetogram sample — signed Br
    vec4 magS = texture2D(uMagTex, vUv);
    float brPos = magS.r, brNeg = magS.b;
    float br = brPos - brNeg; // -1..1
    float strength = clamp(abs(br) * 2.0 * uSpotR, 0.0, 1.0);

    // Limb darkening — wavelength-dependent
    float cosTheta = clamp(dot(vNorm, vView), 0.0, 1.0);
    float limbExp  = uLimb * (1.0 + float(uChannel) * 0.05);
    float limbFac  = pow(cosTheta, limbExp);
    float limbFrac = 1.0 - cosTheta; // 0=disk center, 1=limb edge

    // Granulation (reduced under sunspots — magnetic suppression)
    float granMask = 1.0 - strength * 0.9;
    float gran     = granulation(vUv) * granMask;

    // Sunspot modulation
    vec3 spotMod = sunspot(strength, gran);

    // H-alpha chromospheric fibrils (visible in 304Å and white light)
    float fibrils = chromoNet(vUv, br) * clamp(strength * 1.5, 0.0, 1.0);

    // Spicule jets at limb
    float spic = spicules(vUv, limbFrac);

    // ── PER-CHANNEL RENDERING ──────────────────────────────
    vec3 color;
    float emissionT;

    if(uChannel == 6){ // HMI Magnetogram
      color = lutHMI(br) * spotMod;
      // Show granulation structure faintly beneath
      color += vec3(0.04,0.03,0.01) * gran;

    } else {
      // EUV emission: temperature-dependent.
      // Coronal emission peaks over active regions (high |B|).
      // Emission measure ∝ n²·dV, proxy: emission ~ |B|² * T_eff
      float corEmit = strength * strength * (1.0 + uFlareHeat * 8.0);
      // Quiet corona: base glow from hot loops
      float quietEmit = 0.12 + fbm2(vUv * 4.0 + uTime * 0.03, 3) * 0.08;
      emissionT = clamp(quietEmit + corEmit, 0.0, 1.0);

      // Select wavelength channel
      vec3 euv;
      if(uChannel==0)      euv = lut94(emissionT);
      else if(uChannel==1) euv = lut131(emissionT);
      else if(uChannel==2) euv = lut171(emissionT);
      else if(uChannel==3) euv = lut193(emissionT);
      else if(uChannel==4) euv = lut211(emissionT);
      else                 euv = lut304(emissionT);

      // In 304Å: prominences show as bright loops, chromosphere bright
      float chromoBright = (uChannel == 5) ? (0.3 + fibrils * 0.5 + spic * 1.5) : 0.0;

      // Photosphere base (visible in white-light composite)
      vec3 photo = vec3(0.92,0.62,0.22) * gran;
      float photoBlend = (uChannel >= 3) ? 0.1 : 0.2; // less visible in hot channels

      // Sunspot darkness visible across all channels
      color = (euv + photo * photoBlend + chromoBright) * spotMod;

      // Facular brightening visible in EUV too
      float facFrac = smoothstep(0.3,0.35,strength)*(1.0-smoothstep(0.35,0.45,strength));
      color += vec3(0.1,0.08,0.05) * facFrac * uFaculae;
    }

    // ── LIMB DARKENING (wavelength-specific) ──────────────
    // EUV channels have LIMB BRIGHTENING not darkening in emission
    float limbBoost = (uChannel < 4) ? (1.0 + limbFrac * 0.4) : 0.0;
    float limbDark  = mix(0.25, 1.0, limbFac);
    float finalLimb = (uChannel == 6) ? limbDark : mix(limbDark, limbBoost, 0.6);
    color *= finalLimb;

    // ── FLARE HEATING ─────────────────────────────────────
    if(uFlareHeat > 0.01){
      // Hot plasma brightens, shifts toward blue-white
      float heatBlast = uFlareHeat * strength * 3.0;
      vec3 hotColor = vec3(0.8, 0.9, 1.0) * heatBlast;
      color += hotColor;
      // Kernels: two-ribbon bright patches around AR
      vec2 arPos = vec2(uARLon / 6.2831, uARLat / 3.1416 + 0.5);
      float d1 = length(vUv - (arPos + vec2(0.02, 0.0)));
      float d2 = length(vUv - (arPos - vec2(0.02, 0.0)));
      float kernel = exp(-d1*d1*800.0) + exp(-d2*d2*800.0);
      color += vec3(1.0,0.8,0.4) * kernel * uFlareHeat * 4.0;
    }

    gl_FragColor = vec4(color, 1.0);
  }
`;

const sunShaderMat = new THREE.ShaderMaterial({
  uniforms: sunUniforms,
  vertexShader: sunVert,
  fragmentShader: sunFrag,
});
photoMesh.material = sunShaderMat;

