// Set initial positions
document.getElementById('pan-telem').style.cssText += ';top:12px;right:12px;left:auto;';
document.getElementById('pan-ctrl').style.cssText  += ';top:12px;left:12px;';
document.getElementById('pan-leg').style.cssText   += ';bottom:12px;right:12px;left:auto;';
document.getElementById('pan-lay').style.cssText   += ';bottom:12px;left:12px;';

document.querySelectorAll('.fp').forEach(panel=>{
  const bar = panel.querySelector('.fp-bar');
  if(!bar) return;
  let ox=0,oy=0,px=0,py=0,active=false;
  bar.addEventListener('mousedown',e=>{
    if(e.target.tagName==='BUTTON') return;
    active=true;
    const r=panel.getBoundingClientRect();
    px=r.left; py=r.top; ox=e.clientX; oy=e.clientY;
    panel.style.right='auto'; panel.style.bottom='auto';
    panel.style.left=px+'px'; panel.style.top=py+'px';
    panel.style.zIndex=55;
    e.preventDefault();
  });
  window.addEventListener('mousemove',e=>{
    if(!active) return;
    panel.style.left=Math.max(0,Math.min(window.innerWidth-80,  px+(e.clientX-ox)))+'px';
    panel.style.top =Math.max(0,Math.min(window.innerHeight-26, py+(e.clientY-oy)))+'px';
  });
  window.addEventListener('mouseup',()=>{ active=false; panel.style.zIndex=40; });
  panel.style.resize='both'; panel.style.overflow='auto';
});

window.minPanel  = id=>{ const e=document.getElementById(id); if(e) e.classList.toggle('minimized'); };
window.hidePanel = id=>{ const e=document.getElementById(id); if(e) e.style.display='none'; };

