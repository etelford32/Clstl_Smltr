// Current wind solution state
let windSolution = null;

function updateWindSolution() {
  let maxB = 0.1;
  for (let k=0; k<N; k++) maxB = Math.max(maxB, Math.abs(Br[k]));
  const T_MK = 1.2 + params.A_temp * 0.3; // temperature slider
  windSolution = solveParkerWind(T_MK, maxB);

  // Update velocity profile curve (wind speed)
  const prof = windSolution.profile;
  const step = Math.floor(prof.length / WIND_PLOT_PTS);
  for (let i = 0; i < WIND_PLOT_PTS; i++) {
    const p = prof[Math.min(i*step, prof.length-1)];
    windPlotPos[i*3]   = PLOT_X;
    windPlotPos[i*3+1] = -1.5 + Math.min(p.v_kms, PLOT_V_MAX) * PLOT_SCALE_V;
    windPlotPos[i*3+2] = Math.min(p.r_R, PLOT_R_MAX) * PLOT_SCALE_R;
  }
  windPlotGeo.attributes.position.needsUpdate = true;

  // Update Alfvén speed profile curve (decreasing)
  const v_A0 = maxB * 200; // km/s at 1 R☉
  for (let i = 0; i < WIND_PLOT_PTS; i++) {
    const r_R = 1 + (i / (WIND_PLOT_PTS-1)) * (PLOT_R_MAX - 1);
    const vA  = Math.min(v_A0 / (r_R * r_R), PLOT_V_MAX);
    alfPlotPos[i*3]   = PLOT_X;
    alfPlotPos[i*3+1] = -1.5 + vA * PLOT_SCALE_V;
    alfPlotPos[i*3+2] = r_R * PLOT_SCALE_R;
  }
  alfPlotGeo.attributes.position.needsUpdate = true;

  // Reposition sonic and Alfvén rings in scene space
  const rs = Math.min(windSolution.r_sonic_R, 6.5); // clamp for visual
  const ra = Math.min(windSolution.r_alfven_R, 5.0);
  sonicRingMesh.scale.setScalar(rs);
  alfvenRingMesh.scale.setScalar(ra);

