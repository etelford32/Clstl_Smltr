# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
*.egg-info/

# Rust
# Only the build byproducts are excluded. rust/www/ (including the
# committed star_renderer_bg.wasm) must ship to Vercel because rust.html
# loads it as a static asset. Vercel no longer rebuilds rust/ at deploy
# time (see build-wasm.sh); the committed wasm is the source of truth.
rust/target/

# Git
.git/
.gitignore
# Submodules have a `.git` *file* (not directory) pointing to the parent
# repo's .git/modules/... — exclude those without excluding submodule content.
**/.git
.gitmodules

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker
Dockerfile
docker-compose.yml

# Tests
test_*.py
*_test.py

# Documentation (optional - comment out if you want to deploy docs)
# *.md
# DEPLOYMENT.md
# QUICK_START.md
