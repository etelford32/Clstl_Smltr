        }
      ],
      "fieldConfig": { "defaults": { "unit": "velocitykms" } }
    },
    {
      "type": "timeseries",
      "title": "IMF Bz at L1 (nT, GSM)",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "postgres", "uid": "SWMF-Postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT timestamp_utc AS time, bz_gsm_nT AS bz FROM l1_observations WHERE $__timeFilter(timestamp_utc) ORDER BY timestamp_utc",
