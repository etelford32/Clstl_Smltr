    {
      "type": "timeseries",
      "title": "Solar Wind Speed at L1 (km/s)",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "SWMF-Postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT timestamp_utc AS time, speed_kms AS speed FROM l1_observations WHERE $__timeFilter(timestamp_utc) ORDER BY timestamp_utc",
