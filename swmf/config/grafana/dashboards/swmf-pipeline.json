      "datasource": { "type": "postgres", "uid": "SWMF-Postgres" },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT run_id, run_mode, start_time_utc, forecast_hours, mpi_nproc, status, sim_hours_done, completed_at FROM forecast_runs ORDER BY start_time_utc DESC LIMIT 20",
          "format": "table"
        }
      ]
    }
